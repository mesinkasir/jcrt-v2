---
layout: base.njk
---
<div class="collection-shell collection-shell--author-detail">
  {% include "partials/nav_desktop.njk" %}

  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12 p-3 p-md-5">
        {% set authorKey = page.fileSlug %}
        {% set authorKeySlug = authorKey | authorSlug %}
        {% set postsByAuthor = tagIndex.authors.all.map[authorKeySlug] or tagIndex.authors.all.map[authorKey] or [] %}
        <h1 class="p-name text-center"><strong><span class="none text-dark">{{ title }}</span></strong></h1>

        {% if postsByAuthor.length %}
          <div class="text-center text-secondary mb-5">
            {% set authorProfileImage = (image | ensureImage('/images/jcrt.svg')) if image else (metadata.files_url + '/images/jcrt.svg') %}
            <img class="img-thumb rounded-circle mb-3 reading-author-image" alt="{{ title }}" width="150" height="150"
                 src="{{ authorProfileImage | preferWebp }}" data-fallback-src="{{ authorProfileImage }}" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='{{ metadata.files_url }}/images/jcrt.svg';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'{{ metadata.files_url }}/images/jcrt.svg';}"/>
            {% set authorMeta = affiliation or description %}
            {% if authorMeta %}
              <h2 class="h5 text-primary text-uppercase mb-3">{{ authorMeta }}</h2>
            {% endif %}
            {% if bio %}
              <p class="lead italic mb-3">{{ bio }}</p>
            {% elif description and description != authorMeta %}
              <p class="lead italic mb-3">{{ description }}</p>
            {% endif %}
          
          {% if orcid and orcid != "/" %}
            <div class="mb-3">
              <a href="{{ orcid }}" target="_blank" class="text-decoration-none text-dark small">
                <img src="/images/external/orcid-org-orcid-logo-icon-30cf5199eb.webp" width="16" class="me-1" alt="ORCID">
                {{ orcid | replace("https://orcid.org/", "") }}
              </a>
            </div>
          {% endif %}
            <p>
  {{ postsByAuthor.length }} Posts |

  {% if social %}
    {% for s in social %}
      <a href="{{ s.url | default('#') }}" 
         title="{{ s.title }}" 
         target="_blank" 
         rel="noopener" 
         class="text-decoration-none text-dark me-3"
         aria-label="{{ s.title }} of {{ title }}">
        
        <i class="{{ s.icon }}" aria-hidden="true"></i>

        {% if s.title == "website" %}
          <span class="small ms-1">
            {% if s.url %}
              {{ s.url | replace("https://", "") | replace("http://", "") | replace("www.", "") | replace("/", "") }}
            {% else %}
              Website
            {% endif %}
          </span>
        {% endif %}
      </a>
    {% endfor %}
  {% endif %}
</p>

            <p>
              {% if button %}
                {% for b in button %}
                  <a href="{{ b.url }}" class="btn btn-primary me-2 text-white">{{ b.title }}</a>
                {% endfor %}
              {% endif %}
            </p>
          </div>

          <hr/>
          <div class="row mt-4">
            {% for b in postsByAuthor %}
              <div class="col-md-4 col-lg-4 p-3 p-md-4"> 
                <div class="img-zoom-container mb-3">
                  <a href="{{ b.url }}" title="{{ b.title }}">
                    {% set authorPostImage = (b.image | ensureImage('/images/jcrt-open-graph.webp')) if b.image else (metadata.files_url + '/images/jcrt-open-graph.webp') %}
                    <img class="img-post rounded" alt="{{ b.title }}" src="{{ authorPostImage | preferWebp }}" data-fallback-src="{{ authorPostImage }}" {% imageAttrs authorPostImage, 640, 360 %} loading="lazy" decoding="async" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='{{ metadata.files_url }}/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'{{ metadata.files_url }}/images/jcrt-open-graph.webp';}"/>
                  </a>
                </div>
                <h3 class="h5"><strong>{{ b.title }}</strong></h3>
                <p class="small text-muted">
                  {{ b.description }}
                </p>
                <p>
                  <a href="{{ b.url }}" class="btn  btn-primary">Learn More</a>
                </p>
              </div>
            {% endfor %}
          </div>

        {% else %}
          <div class="text-center p-5">
            <p class="lead">Nothing Post by <strong>{{ title }}</strong>.</p>
          </div>
        {% endif %}

      </div>
    </div>
  </div>
</div>
