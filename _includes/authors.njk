---
layout: base.njk
---
<div class="col-md-10 mx-auto">
  {% include "partials/nav_desktop.njk" %}

  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12 p-3 p-md-5">
        {% set authorKey = page.fileSlug %}
        {% set postsByAuthor = collections.all | getPostsByAuthor(authorKey) %}

        {% if postsByAuthor.length %}
          <div class="text-center text-secondary mb-5">
            <img class="img-thumb rounded-circle mb-3" alt="{{ title }}" width="150" height="150" 
                 style="object-fit:cover;" src="{{ image or '/img/default-author.jpg' }}"/>
            <h1 class="p-name"><strong><span class="none text-dark">{{ title }}</span></strong></h1>
            {% set authorMeta = affiliation or description %}
            {% if authorMeta %}
              <h2 class="h5 text-primary text-uppercase mb-3">{{ authorMeta }}</h2>
            {% endif %}
            {% if bio %}
              <p class="lead italic mb-3">{{ bio }}</p>
            {% elif description and description != authorMeta %}
              <p class="lead italic mb-3">{{ description }}</p>
            {% endif %}
          
          {% if orcid and orcid != "/" %}
            <div class="mb-3">
              <a href="{{ orcid }}" target="_blank" class="text-decoration-none text-dark small">
                <img src="https://orcid.org/assets/vectors/orcid.logo.icon.svg" width="16" class="me-1" alt="ORCID">
                {{ orcid | replace("https://orcid.org/", "") }}
              </a>
            </div>
          {% endif %}
            <p>
              {{ postsByAuthor.length }} Posts |
              {% if social %}
                {% for s in social %}
                  <a href="{{ s.url }}" title="{{ s.title }}"><i class="{{ s.icon }} me-2"></i></a>
                {% endfor %}
              {% endif %}
            </p>

            <p>
              {% if button %}
                {% for b in button %}
                  <a href="{{ b.url }}" class="btn btn-primary me-2 text-white">{{ b.title }}</a>
                {% endfor %}
              {% endif %}
            </p>
          </div>

          <hr/>
          <div class="row mt-4">
            {% for b in postsByAuthor %}
              <div class="col-md-4 col-lg-4 p-3 p-md-4"> 
                <div class="img-zoom-container mb-3">
                  <a href="{{ b.url }}" title="{{ b.data.title }}">
                    <img class="img-post rounded" alt="{{ b.data.title }}" src="{{ b.data.image or '/img/jcrt.svg' }}" {% imageAttrs (b.data.image or '/img/jcrt.svg'), 640, 360 %} loading="lazy" decoding="async"/>
                  </a>
                </div>
                <h3 class="h5"><strong>{{ b.data.title }}</strong></h3>
                <p class="small text-muted">
                  {{ b.data.description }}
                </p>
                <p>
                  <a href="{{ b.url }}" class="btn  btn-primary">Learn More</a>
                </p>
              </div>
            {% endfor %}
          </div>

        {% else %}
          <div class="text-center p-5">
            <p class="lead">Nothing Post by <strong>{{ title }}</strong>.</p>
          </div>
        {% endif %}

      </div>
    </div>
  </div>
</div>
