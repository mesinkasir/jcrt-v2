<!doctype html>
<html lang="{{ metadata.language }}">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
{% include "partials/seo.njk" %}
</head>
<body>
{% include "partials/sidebar.njk" %}
<div id="content-wrapper" class="mse col-md-10 mx-auto ">
{% include "partials/nav_mobile.njk" %}
{% set pagefindWeight = "" %}
{% if page and page.url %}
  {% if page.url.startsWith('/religioustheory/posts/') and not page.url.includes('/religioustheory/posts/page/') %}
    {% set pagefindWeight = "10" %}
  {% elif page.url.startsWith('/religioustheory/categories/') or page.url.startsWith('/religioustheory/tags/') or page.url.startsWith('/religioustheory/posts/page/') %}
    {% set pagefindWeight = "0.2" %}
  {% endif %}
{% endif %}
<main class="h-entry"{% if searchIndex == false %} data-pagefind-ignore{% else %} data-pagefind-body{% if pagefindWeight %} data-pagefind-weight="{{ pagefindWeight }}"{% endif %}{% endif %}>
{{ content | safe }}
</main>
<footer class="site-footer mt-5 pt-3" data-pagefind-ignore>
  <div class="border-top pt-3" style="border-color: #b8b8b8 !important;">
    <p class="small text-secondary mb-0">
      {{ metadata.site_footer.text | safe }} {{ metadata.site_footer.year_start }}-{{ "" | currentYear }}.
    </p>
    <p class="small text-secondary mb-0 mt-2 text-center">
      <a href="{{ metadata.site_footer.url1 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link1 }}</a> |
      <a href="{{ metadata.site_footer.url2 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link2 }}</a> |
      <a href="{{ metadata.site_footer.url3 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link3 }}</a> |
      <a href="{{ metadata.site_footer.url4 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link4 }}</a> |
      <a href="{{ metadata.site_footer.url5 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link5 }}</a>
    </p>
    <p class="h-card visually-hidden mb-0">
      <a class="p-name u-url" href="https://thewhitestonefoundation.org/">The Whitestone Foundation</a>
    </p>
  </div>
</footer>
</div>
<script>
  (function () {
    const fallback = "{{ metadata.files_url }}/images/jcrt-open-graph.webp";
    const cdnBase = "{{ metadata.files_url }}";
    const hasInlineFallback = (img) => img.hasAttribute("onerror");
    const absolutize = (src) => {
      try {
        return new URL(src, window.location.href).href;
      } catch {
        return src || "";
      }
    };
    const toCdnImageSrc = (src) => {
      if (!src) return "";
      if (/^(https?:)?\/\//i.test(src) || src.startsWith("data:")) return "";
      return src.startsWith("/images/") ? `${cdnBase}${src}` : "";
    };
    const nextFallbackSrc = (img) => {
      const currentAttrSrc = img.getAttribute("src") || "";
      const currentResolvedSrc = absolutize(img.currentSrc || img.src || currentAttrSrc);
      const candidates = [img.dataset.fallbackSrc || "", toCdnImageSrc(currentAttrSrc), fallback];
      return candidates.find((candidate) => candidate && absolutize(candidate) !== currentResolvedSrc) || fallback;
    };
    const applyFallback = (img) => {
      if (!img || img.dataset.fallbackApplied === "1") return;
      img.dataset.fallbackApplied = "1";
      img.onerror = null;
      img.src = fallback;
    };
    const handleImageError = (img) => {
      if (!img) return;
      const nextSrc = nextFallbackSrc(img);
      if (img.dataset.fallbackAttempted === "1") {
        applyFallback(img);
        return;
      }
      img.dataset.fallbackAttempted = "1";
      img.src = nextSrc;
    };
    function applyImageFallbacks() {
      const images = document.querySelectorAll("img");
      images.forEach((img) => {
        if (img.dataset.fallbackBound === "1" || hasInlineFallback(img)) return;
        img.dataset.fallbackBound = "1";
        img.onerror = function () {
          handleImageError(this);
        };
      });
    }
    document.addEventListener(
      "error",
      (event) => {
        const img = event.target;
        if (!(img instanceof HTMLImageElement)) return;
        if (hasInlineFallback(img)) return;
        handleImageError(img);
      },
      true
    );
    const observer = new MutationObserver(() => applyImageFallbacks());
    observer.observe(document.documentElement, { childList: true, subtree: true });
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", applyImageFallbacks);
    } else {
      applyImageFallbacks();
    }
  })();
</script>
{% include "partials/icon-sprite.njk" %}
<script defer src="/js/bs.js"></script>
</body>
</html>
