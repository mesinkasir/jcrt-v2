<!doctype html>
<html lang="{{ metadata.language }}">
<meta name="viewport" content="width=device-width, initial-scale=1">
{% include "partials/seo.njk" %}
</head>
<body>
{% include "partials/sidebar.njk" %}
<div id="content-wrapper" class="mse col-md-10 mx-auto ">
{% include "partials/nav_mobile.njk" %}
<main class="h-entry"{% if searchIndex == false %} data-pagefind-ignore{% else %} data-pagefind-body{% endif %}>
{{ content | safe }}
</main>
<footer class="site-footer mt-5 pt-3" data-pagefind-ignore>
  <div class="border-top pt-3" style="border-color: #b8b8b8 !important;">
    <p class="small text-secondary mb-0">
      {{ metadata.site_footer.text | safe }} {{ metadata.site_footer.year_start }}-{{ "" | currentYear }}.
    </p>
    <p class="small text-secondary mb-0 mt-2">
      <a href="{{ metadata.site_footer.url1 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link1 }}</a> |
      <a href="{{ metadata.site_footer.url2 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link2 }}</a> |
      <a href="{{ metadata.site_footer.url3 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link3 }}</a> |
      <a href="{{ metadata.site_footer.url4 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link4 }}</a> |
      <a href="{{ metadata.site_footer.url5 }}" target="_blank" rel="noopener noreferrer">{{ metadata.site_footer.link5 }}</a>
    </p>
    <p class="h-card visually-hidden mb-0">
      <a class="p-name u-url" href="https://thewhitestonefoundation.org/">The Whitestone Foundation</a>
    </p>
  </div>
</footer>
</div>
<script>
  (function () {
    const fallback = "/img/jcrt-open-graph.webp";
    const applyFallback = (img) => {
      if (!img || img.dataset.fallbackApplied === "1") return;
      img.dataset.fallbackApplied = "1";
      img.onerror = null;
      img.src = fallback;
    };
    function applyImageFallbacks() {
      const images = document.querySelectorAll("img");
      images.forEach((img) => {
        if (img.dataset.fallbackBound === "1") return;
        img.dataset.fallbackBound = "1";
        img.onerror = function () {
          if (this.dataset.fallbackAttempted === "1") {
            applyFallback(this);
            return;
          }
          this.dataset.fallbackAttempted = "1";
          this.src = this.dataset.fallbackSrc || fallback;
        };
      });
    }
    document.addEventListener(
      "error",
      (event) => {
        const img = event.target;
        if (!(img instanceof HTMLImageElement)) return;
        if (img.dataset.fallbackAttempted === "1") {
          applyFallback(img);
          return;
        }
        img.dataset.fallbackAttempted = "1";
        img.src = img.dataset.fallbackSrc || fallback;
      },
      true
    );
    const observer = new MutationObserver(() => applyImageFallbacks());
    observer.observe(document.documentElement, { childList: true, subtree: true });
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", applyImageFallbacks);
    } else {
      applyImageFallbacks();
    }
  })();
</script>
<script defer src="/js/bs.js"></script>
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" /></noscript>
</body>
</html>
