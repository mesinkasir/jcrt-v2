---
layout: base.njk
---
{% include "partials/nav_desktop.njk" %}
<div class="container-fluid">
<div class="col-md-12 p-3  p-md-5">
<h2 class="p-name"><strong><span class="bgb-primary">{{title}}</span></strong></h2>
</div>
<div class="row mt-3 mb-3">
{% for b in pagination.items | reverse %}
<div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
<div class="img-zoom-container">
{% set blogCardImage = b.data.image or '/images/jcrt-open-graph.webp' %}
{% set blogCardImagePreferred = blogCardImage | preferWebp %}
<a href="{{b.url}}" title="{{b.data.title}}"><img class="img-post rounded" alt="{{b.data.title}}" src="{{blogCardImagePreferred}}" data-fallback-src="{{blogCardImage}}" {% imageAttrs blogCardImage, 640, 360 %} loading="lazy" decoding="async" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}"/></a>
</div>
<h3>{{b.data.title}}</h3>
<p>
{{b.data.description}}
</p>
<p><a href="{{b.url}}" class="btn  btn-primary p-2" aria-label="Read blog post: {{ b.data.title }}">
Read: {{ b.data.title }}
</a></p>
</div>
{% endfor %}
</div>
{% set totalPages = pagination.pages.length %}
{% set currentPage = pagination.pageNumber + 1 %}

{% if totalPages > 1 %}
  <nav class="pagination-editorial border-top pt-5 mt-5 d-flex align-items-center justify-content-between px-md-5" role="navigation">
      
      <div class="d-flex align-items-center" style="flex: 1;">
          {% if pagination.href.previous %}
              <a href="{{ pagination.href.previous }}" class="btn-editorial-ghost me-3">← Newer</a>
          {% else %}
              <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
          {% endif %}
      </div>

      <div class="text-center d-none d-md-block" style="flex: 1;">
          {% if pagination.href.previous and pagination.href.next %}
              <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
          {% endif %}
      </div>

      <div class="text-end" style="flex: 1;">
          {% if pagination.href.next %}
              <a href="{{ pagination.href.next }}" class="btn-editorial-ghost">Older →</a>
          {% else %}
            {% if pagination.href.previous %}
                <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
              {% endif %}
          {% endif %}
      </div>
  </nav>
{% endif %}

</div>
