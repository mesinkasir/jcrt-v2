<button id="menu-toggle-btn" class="menu-toggle-editorial" aria-label="sidebar menu for navigation">
    <svg class="icon-svg" aria-hidden="true"><use href="#fa-bars"/></svg>
</button>

<section id="sidebar-container" data-pagefind-ignore>
<div id="sidebar-menu">

<div class="mb-3 p-3">
<link rel="preload" href="/pagefind/pagefind-ui.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link href="/pagefind/pagefind-ui.css" rel="stylesheet"></noscript>
<script defer src="/pagefind/pagefind-ui.js"></script>
<div id="search"></div>
<script>
    window.addEventListener('DOMContentLoaded', (event) => {
        const searchEl = document.querySelector("#search");
        const renderFallback = () => {
            if (!searchEl) return;
            searchEl.innerHTML = `
                <form action="/search/" method="get" role="search" style="display:flex;gap:8px;">
                    <input type="search" name="q" placeholder="Search" aria-label="Search" style="flex:1;min-width:0;padding:8px;border:1px solid #ccc;-webkit-appearance:none;box-sizing:border-box;">
                    <button type="submit" class="btn btn-primary btn-sm">Go</button>
                </form>
            `;
        };
        if (typeof PagefindUI !== "function") {
            renderFallback();
            return;
        }
        try {
            new PagefindUI({
                element: "#search",
                showSubResults: true,
                processResult: (result) => {
                    const currentTitle = result?.meta?.title || result?.title || "";
                    if (!currentTitle.trim()) {
                        const cleanPath = (result?.url || "").replace(/\/$/, "");
                        const fallbackTitle = decodeURIComponent(cleanPath.split("/").pop() || result?.url || "Untitled");
                        result.title = fallbackTitle.replace(/[-_]+/g, " ");
                    }
                    return result;
                }
            });
        } catch {
            renderFallback();
        }
    });
</script>
</div>

<div class="p-3 bg-light"> 
		
<h3 class="mb-4"><span class="bgb-primary p-1">{{metadata.sidebar.menu.title}}</span></h3>
<ul class="nav-editorial">
  {% for n in metadata.sidebar.menu.list %}
    <li class="nav-item-editorial">
      <a href="{{n.url}}" class="border-bottom">{{n.nav}}</a>
    </li>
  {% endfor %}
</ul>

<div class="sidebar-section">
    {% for section in metadata.sidebar.info.sections %}
        <h3 class="editorial-heading">{{ section.title }}</h3>
        {% for i in section.list %}
            <div class="editorial-card">
                <a href="{{i.url}}">
                    {% set sideImg = i.image %}
                    {% set sideImgPreferred = sideImg | preferWebp %}
                    <img class="editorial-img sidebar-square-img" src="{{sideImgPreferred}}" data-fallback-src="{{sideImg}}" alt="{{i.text}}" {% imageAttrs sideImg, 400, 400 %} loading="lazy" decoding="async" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}"/>
                </a>
                <p class="editorial-caption">{{i.text}}</p>
            </div>
        {% endfor %}
    {% endfor %}
	<a href="{{metadata.sidebar.info.button.url}}" class="btn btn-s, btn-primary text-uppercase">{{metadata.sidebar.info.button.text}}</a></p>
</div>

			
<div class="smaller">
<h3 class="mt-3 mb-5"><span class="bgb-primary p-1">{{metadata.sidebar.contact.title}}</span></h3>
<p>
{{metadata.sidebar.contact.text}}
</p>
{% for c in metadata.sidebar.contact.list %}<p class="mb-3">
<svg class="icon-svg me-3 text-primary" aria-hidden="true"><use href="#{{c.icon | iconId}}"/></svg>{% if c.url %}<a href="{{c.url}}">{{c.title}}</a>{% else %}{{c.title}}{% endif %}</p><hr/>{% endfor %}
</div>
			
<div class="mt-5">
<p class="smallers">
{{ metadata.sidebar_footer.text | safe }}
</p>
</div>

</div>
</div>
</section>
