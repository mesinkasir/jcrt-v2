{% set archiveConfig = metadata.homepage_archive %}
{% set activeTag = archiveConfig.active_tag | string %}
{% set archivePosts = [] %}

{% for post in collections.archivesSorted %}
  {% if archivePosts.length < archiveConfig.max_items %}
    {% set volIssue = post.data.volume + "." + post.data.issue %}
    {% if (activeTag in post.data.tags) or (activeTag == volIssue) %}
      {% set archivePosts = (archivePosts.push(post), archivePosts) %}
    {% endif %}
  {% endif %}
{% endfor %}

{% if archivePosts.length > 0 %}
<section class="archive-featured-section pt-5">
  <div class="container-fluid px-3 px-md-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <h3 class="m-0 serif fw-bold">
        <span class="border-bottom border-3 border-primary pb-1">{{ archiveConfig.section_title }}</span>
        <span class="ms-2 badge bg-light text-secondary small" style="font-size: 0.5em;">#{{ activeTag }}</span>
      </h3>
      <a href="/archives/" class="text-primary text-decoration-none small fw-bold text-uppercase">Explore All →</a>
    </div>

    <div class="row">
      {% for post in archivePosts %}
        <div class="col-md-4 mb-4">
          <div class="img-zoom-container mb-3 shadow-sm rounded" style="aspect-ratio: 16/9; overflow: hidden;">
            <a href="{{ post.url }}">
              {% set archiveThumb = post.data.image if post.data.image and post.data.image != 'null' else '/img/jcrt-open-graph.webp' %}
              {% responsiveThumb archiveThumb, (post.data.title or "Untitled Document"), "img-fluid w-100 h-100", "(max-width: 767px) 100vw, (max-width: 1199px) 50vw, 33vw", "320,480,640", "lazy", "low", "/img/jcrt-open-graph.webp", "object-fit: cover;" %}
            </a>
          </div>
          
          <h4 class="h6 serif fw-bold mb-1">{{ post.data.title or "Untitled Document" }}</h4>
          
          <p class="small text-muted mb-2">
            By {{ post.data.author or post.data.authors or "Unknown" }}
            {% if post.data.volume %}
              <span class="mx-1">•</span> Vol {{ post.data.volume }}.{{ post.data.issue }}
            {% endif %}
          </p>

          <p class="text-secondary small">
            {{ post.data.description | truncate(170) if post.data.description else post.templateContent | striptags | truncate(170) }}
          </p>
          
          {% set readTitle = post.data.title or "Document" %}
          {% set colonIdx = readTitle.indexOf(":") %}
          {% set semiIdx = readTitle.indexOf(";") %}
          {% set sepIdx = -1 %}
          {% if colonIdx >= 0 and (semiIdx < 0 or colonIdx < semiIdx) %}
            {% set sepIdx = colonIdx %}
          {% elif semiIdx >= 0 %}
            {% set sepIdx = semiIdx %}
          {% endif %}
          {% if sepIdx >= 0 %}
            {% set readTitle = readTitle.substring(0, sepIdx) %}
          {% endif %}
          <a href="{{ post.url }}" class="btn btn-link p-0 text-primary text-decoration-none fw-bold small">Read {{ readTitle | trim | lower }}</a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
