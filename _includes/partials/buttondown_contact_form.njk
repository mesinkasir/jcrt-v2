{% set buttondownUser = buttondown_username or metadata.buttondown_username or "jcrt" %}
{% set buttondownEndpoint = "https://buttondown.com/api/emails/embed-subscribe/" ~ buttondownUser %}

<section class="col-md-10 mx-auto py-4">
  <div class="row justify-content-center">
    <div class="col-lg-9">
      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-4 p-md-5">
          <div class="mb-4">
            <p class="text-uppercase small fw-bold text-primary mb-2" style="letter-spacing: 0.08em;">Newsletter Signup</p>
            <h1 class="serif fw-bold mb-2">Subscribe to JCRT Updates</h1>
            <p class="text-secondary mb-0">Receive calls for papers, publication notices, and new issue announcements.</p>
          </div>

          <form
            x-data="{
              endpoint: '{{ buttondownEndpoint }}',
              form: { name: '', affiliation: '', email: '', consent: false },
              loading: false,
              status: '',
              error: '',
              async submit() {
                this.status = '';
                this.error = '';
                if (!this.form.consent) {
                  this.error = 'Please consent to receive email updates.';
                  return;
                }
                this.loading = true;
                try {
                  const response = await fetch(this.endpoint, {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                      email: this.form.email,
                      metadata: {
                        name: this.form.name,
                        affiliation: this.form.affiliation
                      }
                    })
                  });
                  if (!response.ok) {
                    throw new Error('Subscription failed.');
                  }
                  this.status = 'Thanks for subscribing. Please check your inbox to confirm.';
                  this.form = { name: '', affiliation: '', email: '', consent: false };
                } catch (err) {
                  this.error = 'We could not complete your signup. Please try again.';
                } finally {
                  this.loading = false;
                }
              }
            }"
            @submit.prevent="submit"
            class="jcrt-subscribe-form"
            novalidate
          >
            <div class="row g-3">
              <div class="col-md-6">
                <label for="sub-name" class="form-label fw-semibold">Name</label>
                <input id="sub-name" type="text" class="form-control form-control-lg" x-model.trim="form.name" required>
              </div>
              <div class="col-md-6">
                <label for="sub-affiliation" class="form-label fw-semibold">Affiliation</label>
                <input id="sub-affiliation" type="text" class="form-control form-control-lg" x-model.trim="form.affiliation">
              </div>
              <div class="col-12">
                <label for="sub-email" class="form-label fw-semibold">Email Address</label>
                <input id="sub-email" type="email" class="form-control form-control-lg" x-model.trim="form.email" required>
              </div>
              <div class="col-12">
                <label class="form-check d-flex align-items-start gap-2">
                  <input type="checkbox" class="form-check-input mt-1" x-model="form.consent" required>
                  <span class="form-check-label text-secondary">
                    I consent to receive email communications from JCRT.
                  </span>
                </label>
              </div>
              <div class="col-12 d-flex flex-wrap align-items-center gap-3">
                <button
                  type="submit"
                  class="btn btn-primary px-4 py-2 fw-bold text-uppercase"
                  style="letter-spacing: 0.06em;"
                  :disabled="loading || !form.email || !form.name || !form.consent"
                >
                  <span x-show="!loading">Subscribe</span>
                  <span x-show="loading">Submitting...</span>
                </button>
                <p class="mb-0 small text-success fw-semibold" x-show="status" x-text="status"></p>
                <p class="mb-0 small text-danger fw-semibold" x-show="error" x-text="error"></p>
              </div>
            </div>
          </form>

          <noscript>
            <div class="mt-4">
              <p class="small mb-2">JavaScript is disabled. Use the direct signup form:</p>
              <form action="{{ buttondownEndpoint }}" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.com/{{ buttondownUser }}', 'popupwindow')">
                <label for="bd-email-fallback" class="form-label fw-semibold">Email Address</label>
                <input id="bd-email-fallback" type="email" name="email" class="form-control mb-3" required>
                <button type="submit" class="btn btn-primary">Subscribe</button>
              </form>
            </div>
          </noscript>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
