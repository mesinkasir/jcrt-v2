<div class="container-fluid">
<div class="row mt-5 mb-3 align-items-center">
{% if image %}
<div class="col-md-6 p-3 p-md-5">
<div class="col-md-10">
<h1 class="hero-title p-name"><strong>{{title or metadata.title}}</strong></h1>
<h2 class="mt-3 mb-4">{{description or metadata.description}}</h2>
<p>{{text}}</p>
<p><a href="{{button.url}}" class="btn btn-primary text-uppercase">{{button.text}}</a></p>
</div>
</div>
<div class="col-md-6 p-3 p-md-5 d-flex justify-content-center align-items-center">
<div class="ratio ratio-1x1 rounded overflow-hidden">
{% set heroImage = image %}
{% set heroImagePreferred = heroImage | preferWebp %}
<img class="img-fluid w-100 h-100" alt="{{title}}" src="{{heroImagePreferred}}" data-fallback-src="{{heroImage}}" {% imageAttrs heroImage, 1200, 1200 %} loading="eager" fetchpriority="high" decoding="async" style="object-fit: cover;" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='{{ metadata.files_url }}/images/jcrt.svg';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'{{ metadata.files_url }}/images/jcrt.svg';}"/>
</div>
</div>
{% else %}
<div class="col-md-12 p-3 p-md-5">
<div class="col-md-8">
<h1 class="hero-title p-name"><strong>{{title or metadata.title}}</strong></h1>
<h2 class="mt-3 mb-4">{{description or metadata.description}}</h2>
<p>{{text}}</p>
<p><a href="{{button.url}}" class="btn btn-primary text-uppercase">{{button.text}}</a></p>
</div>
</div>
{% endif %}
</div>
</div>
