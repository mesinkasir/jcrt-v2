<div class="collection-shell collection-shell--home-posts">
<div class="col-md-12 p-3  p-md-5">
<h2><span class="border-bottom border-4 border-primary pb-2">{{blog.title}}</span></h2>
</div>
<div class="row mt-3 mb-3">
{% for b in collections.posts | reverse | limit(6) %}
<div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
<div class="img-zoom-container">
<a href="{{b.url}}" title="{{b.data.title}}">
    {% set postListImage = (b.data.image | ensureImage('/images/jcrt-open-graph.webp')) if b.data.image else (metadata.files_url + '/images/jcrt-open-graph.webp') %}
    {% set postListImagePreferred = postListImage | preferWebp %}
    <img class="img-post" alt="{{b.data.title}}" src="{{postListImagePreferred}}" data-fallback-src="{{postListImage}}" {% imageAttrs postListImage, 640, 360 %} loading="lazy" decoding="async" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='{{ metadata.files_url }}/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'{{ metadata.files_url }}/images/jcrt-open-graph.webp';}"/></a>
</div>
<h3>{{b.data.title}}</h3>
<p>
{{b.data.description}}
</p>
<p><a href="{{b.url}}" class="btn btn-primary rounded-pill px-4" aria-label="Read blog post: {{ b.data.title }}">Read: {{ b.data.title }}</a></p>
</div>
{% endfor %}
<div class="col-md-12 p-3  p-md-5 text-center">
<a href="{{blog.button.url}}" class="btn btn-primary rounded-pill px-5">{{blog.button.text}}</a>
</div>
</div>
</div>
