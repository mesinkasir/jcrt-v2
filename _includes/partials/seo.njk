<meta content="{{ pageDesc }}" property="og:description" />
<meta content="{{ pageDesc }}" name="twitter:description" />
<meta property="twitter:card" content="summary_large_image" />
<meta content="{{ pageImage }}" name="twitter:image" />
<meta content="{{ pageImage }}" property="facebook:image" />
<meta content="{{ pageImage }}" property="og:image" />
<meta content="{{ pageTitle }}" property="og:image:alt" />
<meta content="{{ canonicalUrl }}" property="og:url" />
<link rel="icon" type="image/png" href="/img/logos/favicon-96x96.webp" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/img/logos/favicon.svg" />
<link rel="shortcut icon" href="/img/logos/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/img/logos/apple-touch-icon.webp" />
<meta name="apple-mobile-web-app-title" content="{{ metadata.title }}" />
<script>
(() => {
  const addManifest = () => {
    if (document.querySelector('link[rel="manifest"]')) return;
    const link = document.createElement("link");
    link.rel = "manifest";
    link.href = "/img/logos/site.webmanifest";
    document.head.appendChild(link);
  };
  const schedule = () => {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(addManifest, { timeout: 3000 });
    } else {
      setTimeout(addManifest, 1500);
    }
  };
  if (document.readyState === "complete") schedule();
  else window.addEventListener("load", schedule, { once: true });
})();
</script>
