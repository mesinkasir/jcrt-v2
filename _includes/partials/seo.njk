{% set pageUrl = page.url | default("", true) %}
{% set defaultAuthor = "Religious Theory Editors" if "/religioustheory/" in pageUrl else "JCRT Editors" %}
{% set authorCandidate = author or authors or pg.authorName or post.authorName or metadata.site.author or defaultAuthor %}
{% set authorName = authorCandidate %}
{% if (not authorName) or (authorName | trim == "") or (authorName | lower in ["editors", "editor", "editors_religioustheory"]) %}
  {% set authorName = defaultAuthor %}
{% endif %}
{% set pageTitle = seoTitle or title or metadata.title %}
{% if pageUrl == "/" %}
  {% set pageTitle = "JCRT" %}
{% endif %}
{% set rawPageDesc = seoDescription or description or excerpt or abstract or "" %}
{% set pageDesc = rawPageDesc | seoDescription(pageTitle, pageUrl, authorName, volume, issue, season, metadata.description) %}
{% set fullTitle = pageTitle | seoTitle(pageUrl, authorName, volume, issue, season) %}
{% set pageImageSource = thumbnail or image or (metadata.files_url + '/images/jcrt-open-graph.webp') %}
{% set pageImageRaw = pageImageSource | ensureImage('/images/jcrt-open-graph.webp') %}
{% set pageImage = pageImageRaw if "http" in pageImageRaw else (pageImageRaw | assetUrl) %}
{% set robotsDirective = "index, follow" %}
{% if robots %}
  {% set robotsDirective = robots %}
{% elif noindex or draft %}
  {% set robotsDirective = "noindex, follow" %}
{% elif nofollow %}
  {% set robotsDirective = "index, nofollow" %}
{% endif %}
{% set canonicalPath = (canonical_url or pageUrl) | stripQueryAndHash %}
{% set canonicalUrl = canonicalPath if "http" in canonicalPath else metadata.url + canonicalPath %}
{% set publishedDateRaw = date or page.date or post.date %}
{% if (not publishedDateRaw) and year %}
  {% set publishedDateRaw = year ~ "-01-01" %}
{% endif %}
{% set publishedDate = publishedDateRaw | isoDate if publishedDateRaw else metadata.buildTime %}
{% set modifiedDateRaw = lastmod or modified or updated or publishedDateRaw %}
{% set modifiedDate = modifiedDateRaw | isoDate if modifiedDateRaw else publishedDate %}

