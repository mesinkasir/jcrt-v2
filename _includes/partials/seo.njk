{% set pageTitle = title or metadata.title %}
{% set pageDesc = description or excerpt or metadata.description %}
{% set pageImage = image or metadata.image or '/img/jcrt-open-graph.png' %}

<title>{{ pageTitle }}</title>
<meta content="{{ pageTitle }}" property="og:title" />
<meta content="{{ pageTitle }}" property="dc:title" />
<meta content="{{ pageTitle }}" name="twitter:title" />
<meta content="{{ pageTitle }}" name="title" />
<meta content="{{ pageTitle }}" property="og:site_name" />
<meta content="{{ pageDesc }}" name="description" />
<meta content="{{ pageDesc }}" property="facebook:description" />
<meta content="{{ pageDesc }}" property="og:description" />
<meta content="{{ pageDesc }}" name="twitter:description" />
<meta property="twitter:card" content="summary_large_image" />
<meta content="{{ pageImage }}" name="twitter:image" />
<meta content="{{ pageImage }}" property="facebook:image" />
<meta content="{{ pageImage }}" property="og:image" />
<meta content="{{ pageTitle }}" property="og:image:alt" />
<meta content="{{ metadata.url }}{{ page.url }}" property="og:url" />
<link rel="icon" type="image/png" href="/img/logos/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/img/logos/favicon.svg" />
<link rel="shortcut icon" href="/img/logos/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/img/logos/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="{{ metadata.title }}" />
<link rel="manifest" href="/img/logos/site.webmanifest" />
<meta content="{{ metadata.metasocial.facebook }}" property="facebook:author" />
<meta content="{{ metadata.metasocial.twitteruser }}" property="twitter:author" />
<meta property="dc:creator" content="{{ metadata.author.name }}" />
<meta content="{{ metadata.metasocial.twitter }}" name="twitter:site" />
<meta property="og:type" content="website" />
<meta content="index, follow" name="robots">
<link rel="canonical" href="{{ metadata.url }}{{ page.url }}" />
<link rel="alternate" type="application/atom+xml" title="{{ metadata.title }}" href="{{ metadata.url }}/feed/feed.xml" />
<link rel="alternate" type="application/rss+xml" title="{{ metadata.title }}" href="{{ metadata.url }}/feed/feed.rss" />
<link rel="sitemap" type="application/xml" title="{{ metadata.title }} Sitemap" href="{{ metadata.url }}/sitemap.xml" />
<meta name="language" content="{{ metadata.language }}" />
<meta name="locale" content="{{ metadata.locale }}" />
<meta property="og:locale" content="{{ metadata.locale }}" />
<meta name="generator" content="{{ eleventy.generator }}" />
<meta name="site-generator" content="{{ eleventy.generator }}" />
<style>{% include "css/bs.css" %}</style>
<style>{% getBundle "css" %}</style>
<link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,300i,600,600i" rel="stylesheet">
<link href="/css/index.css" rel="stylesheet"/>
<link href="/css/font.css" rel="stylesheet"/>

<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "NGO",
    "@id": "https://thewhitestonefoundation.org",
    "name": "The Whitestone Foundation",
    "url": "https://thewhitestonefoundation.org",
    "logo": "{{ metadata.url }}{{ metadata.favicon }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Boulder",
      "addressRegion": "CO",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "{{ metadata.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ metadata.url }}/search/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
]
</script>

{% set isAcademic = "/archives/" in page.url %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ 'ScholarlyArticle' if isAcademic else 'BlogPosting' }}",
  "headline": "{{ pageTitle }}",
  "description": "{{ pageDesc | truncate(160) }}",
  "image": "{{ pageImage }}",
  "datePublished": "{{ date | isoDate if date else metadata.buildTime }}",
  "dateModified": "{{ date | isoDate if date else metadata.buildTime }}",
  "author": {
    "@type": "Person",
    "name": "{{ author or pg.authorName or post.authorName or metadata.author.name }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "The Whitestone Foundation",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ metadata.url }}{{ metadata.favicon }}"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ metadata.url }}{{ page.url }}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ metadata.url }}"
    },
    {% if pg or post %}
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Religious Theory",
      "item": "{{ metadata.url }}/religioustheory/"
    },
    {% endif %}
    {
      "@type": "ListItem",
      "position": {{ 3 if (pg or post) else 2 }},
      "name": "{{ pageTitle }}",
      "item": "{{ metadata.url }}{{ page.url }}"
    }
  ]
}
</script>
