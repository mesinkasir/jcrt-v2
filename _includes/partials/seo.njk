{% set isAcademic = "/archives/" in page.url %}
{% set isBlogHome = page.url in ["/blog/", "/religioustheory/"] %}
{% set isBlogPost = ("/blog/" in page.url or "/religioustheory/" in page.url) and (not isBlogHome) and (not isAcademic) %}
{% set pageSchemaType = "ScholarlyArticle" if isAcademic else ("Blog" if isBlogHome else ("BlogPosting" if isBlogPost else "WebPage")) %}
{% set schemaAuthors = authorName | splitAuthors %}

{# ── Dublin Core article + Google Scholar citation tags (archive pages only) ── #}
{% if isAcademic %}
  <meta property="dc:type" content="article" />
  <meta property="dc:date" content="{{ publishedDate }}" />
  <meta property="dc:identifier" content="{{ canonicalUrl }}" />
  <meta property="dc:identifier" content="ISSN:1530-5228" />
  <meta property="dc:source" content="The Journal for Cultural and Religious Theory, ISSN 1530-5228" />
  {% if pageDesc %}<meta property="dc:description" content="{{ pageDesc }}" />{% endif %}
  {% for kw in (keywords or []) %}
  <meta property="dc:subject" content="{{ kw | replace('-', ' ') }}" />
  {% endfor %}
  {% for aName in schemaAuthors %}
  <meta property="dc:creator" content="{{ aName }}" />
  <meta name="citation_author" content="{{ aName }}" />
  {% endfor %}
  <meta name="citation_title" content="{{ pageTitle }}" />
  <meta name="citation_journal_title" content="The Journal for Cultural and Religious Theory" />
  <meta name="citation_issn" content="1530-5228" />
  <meta name="citation_publication_date" content="{{ publishedDate }}" />
  <meta name="citation_fulltext_html_url" content="{{ canonicalUrl }}" />
  {% if volume %}<meta name="citation_volume" content="{{ volume }}" />{% endif %}
  {% if issue %}<meta name="citation_issue" content="{{ issue }}" />{% endif %}
  {% if pages %}
    {% set pageRange = pages | parsePageRange %}
    {% if pageRange.start %}<meta name="citation_firstpage" content="{{ pageRange.start }}" />{% endif %}
    {% if pageRange.end %}<meta name="citation_lastpage" content="{{ pageRange.end }}" />{% endif %}
  {% endif %}
  {% if pdf %}
  <meta name="citation_pdf_url" content="{{ metadata.url }}/archives/{{ volume }}.{{ issue }}/{{ pdf }}" />
  {% endif %}
{% elif "/authors/" in page.url %}
  <meta property="dc:type" content="text" />
  <meta property="dc:creator" content="{{ pageTitle }}" />
{% else %}
  <meta property="dc:type" content="text" />
{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ pageSchemaType }}",
  "headline": "{{ pageTitle }}",
  "description": "{{ pageDesc | truncate(160) }}",
  "image": "{{ pageImage }}",
  "datePublished": "{{ publishedDate }}",
  "dateModified": "{{ modifiedDate }}",
  "author":
  {% if isAcademic %}
    {% if schemaAuthors and (schemaAuthors | length > 1) %}
    [
      {%- for aName in schemaAuthors %}
      {% set authorObj = collections.authors | getAuthorObj(aName) %}
      {% set authorPath = authorObj.url if authorObj and authorObj.url else ("/authors/" ~ (aName | authorSlug) ~ "/") %}
      {
        "@type": "Person",
        "name": {{ (aName | trim) | dump | safe }},
        "url": "{{ metadata.url }}{{ authorPath }}"
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
    {% else %}
    {% set singleName = (schemaAuthors[0] | trim) if (schemaAuthors and (schemaAuthors | length > 0)) else authorName %}
    {% set singleAuthorObj = collections.authors | getAuthorObj(singleName) %}
    {% set singleAuthorPath = singleAuthorObj.url if singleAuthorObj and singleAuthorObj.url else ("/authors/" ~ (singleName | authorSlug) ~ "/") %}
    {
      "@type": "Person",
      "name": {{ singleName | dump | safe }},
      "url": "{{ metadata.url }}{{ singleAuthorPath }}"
    }
    {% endif %}
  {% else %}
    {
      "@type": "Person",
      "name": {{ authorName | dump | safe }}
    }
  {% endif %},
  "publisher": {
    "@type": "Organization",
    "name": "The Whitestone Foundation",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ metadata.url }}{{ metadata.favicon }}"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ canonicalUrl }}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ metadata.url }}"
    },
    {% if pg or post %}
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Religious Theory",
      "item": "{{ metadata.url }}/religioustheory/"
    },
    {% endif %}
    {
      "@type": "ListItem",
      "position": {{ 3 if (pg or post) else 2 }},
      "name": "{{ pageTitle }}",
      "item": "{{ canonicalUrl }}"
    }
  ]
}
</script>
