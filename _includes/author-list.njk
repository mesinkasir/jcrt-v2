---
layout: base.njk
---
<div class="jcrt-frame jcrt-frame--authors">
  {% include "partials/nav_desktop.njk" %}
  <section class="jcrt-section jcrt-author-list">
    <header class="jcrt-section-header">
      <h1 class="jcrt-section-title p-name">{{ title }}</h1>
    </header>

    <div class="jcrt-card-grid jcrt-card-grid--authors">
      {% for a in collections.authors %}
        {% set authorName = a.data.name or a.data.title %}
        {% set authorThumb = (a.data.image | ensureImage('/images/jcrt.svg')) if a.data.image else (metadata.files_url + '/images/jcrt.svg') %}
        <article class="jcrt-card jcrt-author-card h-card">
          <a class="jcrt-card-media p-url" href="{{ a.url }}" title="{{ authorName }}">
            <img class="jcrt-card-image u-photo"
                 alt="{{ authorName }}"
                 src="{{ authorThumb | preferWebp }}"
                 data-fallback-src="{{ authorThumb }}"
                 {% imageAttrs authorThumb, 300, 300 %}
                 loading="lazy"
                 decoding="async"
                 onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='{{ metadata.files_url }}/images/jcrt.svg';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'{{ metadata.files_url }}/images/jcrt.svg';}"/>
          </a>
          <div class="jcrt-card-body">
            <h2 class="jcrt-card-title">
              <a class="p-name p-url" href="{{ a.url }}">{{ authorName }}</a>
            </h2>
            {% if a.data.affiliation or a.data.organization or a.data.description %}
              <p class="jcrt-card-excerpt">{{ a.data.affiliation or a.data.organization or a.data.description }}</p>
            {% endif %}
            <a class="jcrt-card-action" href="{{ a.url }}">About {{ authorName }}</a>
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
</div>
