<!DOCTYPE html>
<html lang="{{ metadata.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set pageTitle = title or pg.title or post.title or metadata.site.title %}
  {% set pageDesc = description or excerpt or abstract or pg.excerpt or post.excerpt or (content | striptags | trim | truncate(160)) or metadata.site.description %}
  {% set pageImageRaw = image or metadata.image or '/img/jcrt-open-graph.png' %}
  {% set pageImage = pageImageRaw if "http" in pageImageRaw else metadata.url + pageImageRaw %}
  {% set defaultAuthor = "Religious Theory Editors" %}
  {% set pageAuthorCandidate = author or authors or pg.authorName or post.authorName or metadata.site.author or defaultAuthor %}
  {% set pageAuthor = pageAuthorCandidate %}
  {% if (not pageAuthor) or (pageAuthor | trim == "") or (pageAuthor | lower in ["editors", "editor", "editors_religioustheory"]) %}
    {% set pageAuthor = defaultAuthor %}
  {% endif %}
  {% set publishedDateRaw = date or post.date or page.date %}
  {% if (not publishedDateRaw) and year %}
    {% set publishedDateRaw = year ~ "-01-01" %}
  {% endif %}
  {% set publishedDate = publishedDateRaw | isoDate if publishedDateRaw else metadata.buildTime %}
  {% set modifiedDateRaw = lastmod or modified or updated or publishedDateRaw %}
  {% set modifiedDate = modifiedDateRaw | isoDate if modifiedDateRaw else publishedDate %}

  <title>{{ pageTitle }}</title>
  <meta name="title" content="{{ pageTitle }}" />
  <meta name="description" content="{{ pageDesc }}" />
  <meta name="language" content="{{ metadata.language }}" />
  <meta name="robots" content="index, follow">
  <meta name="generator" content="{{ eleventy.generator }}" />
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}" />
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDesc }}" />
  <meta property="og:image" content="{{ pageImage }}" />
  <meta property="og:site_name" content="{{ metadata.site.title }}" />
  <meta property="og:locale" content="{{ metadata.locale }}" />
  <meta property="facebook:image" content="{{ pageImage }}" />
  <meta property="facebook:description" content="{{ pageDesc }}" />
  <meta property="facebook:author" content="{{ metadata.metasocial.facebook }}" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="{{ metadata.metasocial.twitter }}" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDesc }}" />
  <meta name="twitter:image" content="{{ pageImage }}" />
  <meta property="twitter:author" content="{{ metadata.metasocial.twitteruser }}" />

  <meta property="dc:title" content="{{ pageTitle }}" />
  <meta property="dc:creator" content="{{ pageAuthor }}" />
  <meta name="locale" content="{{ metadata.locale }}" />

  <link rel="icon" href="/img/logos/JCRT.svg" type="image/svg+xml" />
  <link rel="icon" href="/img/logos/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="icon" href="/img/logos/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/img/logos/favicon-48x48.png" type="image/png" sizes="48x48" />
  <link rel="icon" href="/img/logos/android-chrome-192x192.png" type="image/png" sizes="192x192" />
  <link rel="icon" href="/img/logos/android-chrome-512x512.png" type="image/png" sizes="512x512" />
  <link rel="apple-touch-icon" href="/img/logos/apple-touch-icon.png" sizes="180x180" />
  <link rel="manifest" href="/img/logos/site.webmanifest" />
  <meta name="theme-color" content="#ffffff" />

  <!-- use application/atom+xml for an atom feed -->
  <link rel="alternate" href="{{ metadata.url }}/feed/feed.xml" type="application/atom+xml" title="{{ metadata.site.title }}" />
  <link rel="alternate" href="{{ metadata.url }}/feed/feed.rss" type="application/rss+xml" title="{{ metadata.site.title }}" />
  <link rel="sitemap" href="{{ metadata.url }}/sitemap.xml" type="application/xml" title="{{ metadata.site.title }} Sitemap" />
  <meta name="site-generator" content="{{ eleventy.generator }}" />

  <style>{% include "css/bs.css" %}</style>
  <style>{% getBundle "css" %}</style>
  <link href="/css/index.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" rel="stylesheet">
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "NGO",
    "@id": "https://thewhitestonefoundation.org",
    "name": "The Whitestone Foundation",
    "url": "https://thewhitestonefoundation.org",
    "logo": "{{ metadata.url }}{{ metadata.favicon }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Boulder",
      "addressRegion": "CO",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "{{ metadata.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ metadata.url }}/search/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
]
</script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ pageTitle }}",
    "description": "{{ pageDesc | truncate(160) }}",
    "image": "{{ pageImage }}",
    "datePublished": "{{ publishedDate }}",
    "dateModified": "{{ modifiedDate }}",
    "author": {
      "@type": "Person",
      "name": "{{ pageAuthor }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.site.title }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ metadata.url }}{{ metadata.favicon }}"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ metadata.url }}{{ page.url }}"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ metadata.url }}"
      },
      {% if pg or post %}
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Religious Theory",
        "item": "{{ metadata.url }}/religioustheory/"
      },
      {% endif %}
      {
        "@type": "ListItem",
        "position": {{ 3 if (pg or post) else 2 }},
        "name": "{{ pageTitle }}",
        "item": "{{ metadata.url }}{{ page.url }}"
      }
    ]
  }
  </script>
</head>
<body>
  {% include "partials/sidebar.njk" %}
<div id="content-wrapper" class="mse col-md-10 mx-auto ">
    <div class="col-md-12 p-3 mt-3 shadow rounded alert alert-danger alert-dismissible fade show" role="alert">
  {{metadata.site.alert |md | safe }}
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

    {% include "partials/nav_mobile.njk" %}
    <main class="h-entry" data-pagefind-body>
      {{ content | safe }}
      {% if risCitationUrl or jsonCitationUrl %}
        <section class="my-4 pt-3 border-top">
          <div class="d-flex flex-wrap gap-2">
            {% if risCitationUrl %}
              <a href="{{ risCitationUrl }}" title="Download citation as RIS" class="btn btn-outline-primary" download>Download RIS</a>
            {% endif %}
            {% if jsonCitationUrl %}
              <a href="{{ jsonCitationUrl }}" title="Download citation as JSON" class="btn btn-outline-secondary" download>Download JSON</a>
            {% endif %}
          </div>
        </section>
      {% endif %}
    </main>
  </div>
  <script src="/js/bs.js"></script>
</body>
</html>
