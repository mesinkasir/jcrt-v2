  {% set isAcademic = "/archives/" in page.url %}
  {% set isBlogHome = page.url in ["/blog/", "/religioustheory/"] %}
  {% set isBlogPost = ("/blog/" in page.url or "/religioustheory/" in page.url) and (not isBlogHome) and (not isAcademic) %}
  {% set pageSchemaType = "ScholarlyArticle" if isAcademic else ("Blog" if isBlogHome else ("BlogPosting" if isBlogPost else "WebPage")) %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{{ pageSchemaType }}",
    "headline": "{{ pageTitle }}",
    "description": "{{ pageDesc | truncate(160) }}",
    "image": "{{ pageImage }}",
    "datePublished": "{{ publishedDate }}",
    "dateModified": "{{ modifiedDate }}",
    "author": {
      "@type": "Person",
      "name": "{{ pageAuthor }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.site.title }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ metadata.url }}{{ metadata.favicon }}"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ metadata.url }}"
      },
      {% if pg or post %}
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Religious Theory",
        "item": "{{ metadata.url }}/religioustheory/"
      },
      {% endif %}
      {
        "@type": "ListItem",
        "position": {{ 3 if (pg or post) else 2 }},
        "name": "{{ pageTitle }}",
        "item": "{{ canonicalUrl }}"
      }
    ]
  }
  </script>
</head>
<body>
  {% include "partials/sidebar.njk" %}
<div id="content-wrapper" class="mse col-md-10 mx-auto ">
    <div class="col-md-12 p-3 mt-3 shadow rounded alert alert-danger alert-dismissible fade show" role="alert">
  {{metadata.site.alert |md | safe }}
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

    {% include "partials/nav_mobile.njk" %}
    {% set pagefindWeight = "1" %}
    {% if page and page.url %}
      {% if page.url.startsWith('/religioustheory/posts/') and not page.url.includes('/religioustheory/posts/page/') %}
        {% set pagefindWeight = "10" %}
      {% elif page.url.startsWith('/religioustheory/categories/') or page.url.startsWith('/religioustheory/tags/') or page.url.startsWith('/religioustheory/posts/page/') %}
        {% set pagefindWeight = "0.2" %}
      {% endif %}
    {% endif %}
    <main class="h-entry"{% if searchIndex == false %} data-pagefind-ignore{% else %} data-pagefind-body data-pagefind-weight="{{ pagefindWeight }}"{% endif %}>
      {% if title %}<span class="visually-hidden" data-pagefind-meta="title">{{ title }}</span>{% endif %}
      <div class="d-flex justify-content-end mb-3" data-pagefind-ignore>
        <a
          href="{{ shareOpenlyHref }}"
          class="btn btn-outline-secondary btn-sm"
          target="_blank"
          rel="noopener noreferrer"
          title="Share this page with ShareOpenly"
          aria-label="Share this page with ShareOpenly"
        >
          Share via ShareOpenly
        </a>
      </div>
      {% set isTheoryPostDetail = page and page.inputPath and ("/content/religioustheory/posts/" in page.inputPath) %}
      {% if isTheoryPostDetail %}
        {% set defaultPostImage = "/img/jcrt-open-graph.webp" %}
        {% set postImage = (image | ensureImage(defaultPostImage)) %}
        {% set postImagePreferred = (postImage | preferWebp) %}
        {% set postAuthorRaw = author or authors %}
        {% set postAuthorNames = postAuthorRaw | splitAuthors if postAuthorRaw else [] %}
        {% set postDate = date or page.date %}
        {% set postCategories = categories or [] %}
        {% set postTags = tags | filterTagList if tags else [] %}

        <div class="container-fluid">
          <article class="py-4">
            <header class="mb-5 pb-2 border-bottom">
              <h1 class="serif fw-bold display-4 mb-4 p-name">{{ title }}</h1>

              <div class="mb-4">
                <img
                  src="{{ postImagePreferred }}"
                  data-fallback-src="{{ postImage }}"
                  alt="{{ title }}"
                  class="img-fluid rounded shadow-sm w-100"
                  {% imageAttrs postImage, 1200, 675 %}
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  style="max-height: 460px; object-fit: cover;"
                  onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/img/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/img/jcrt-open-graph.webp';}"
                >
              </div>

              {% if postAuthorNames and (postAuthorNames | length > 0) %}
                <div class="text-muted mb-2 p-author h-card">
                  <span class="fw-bold text-dark">By </span>
                  <span class="fw-bold text-dark p-name u-url">
                    {%- for aName in postAuthorNames -%}
                      {% set authorObj = collections.authors | getAuthorObj(aName) %}
                      {%- if (aName | lower) in ["editors", "editor"] -%}
                        <a href="/editors/" class="text-decoration-underline text-dark hover-primary">{{ aName }}</a>
                      {%- elif authorObj -%}
                        <a href="{{ authorObj.url }}" class="text-decoration-underline text-dark hover-primary">{{ aName }}</a>
                      {%- else -%}
                        {{ aName }}
                      {%- endif -%}
                      {%- if not loop.last -%}; {% endif -%}
                    {%- endfor -%}
                  </span>
                </div>
              {% endif %}

              {% if postDate %}
                <div class="small text-muted dt-published">
                  <i class="bi bi-calendar3"></i> {{ postDate | postDate }}
                </div>
              {% endif %}
            </header>

            <section class="article-body serif lh-lg e-content" style="font-size: 1.1rem;">
              {{ content | safe }}
            </section>

            {% if (postCategories and postCategories.length > 0) or (postTags and postTags.length > 0) %}
              <footer class="mt-5 pt-4 border-top">
                <div class="row g-4">
                  <div class="col-12 col-md-6">
                    <h2 class="h6 text-uppercase fw-bold small text-muted mb-2">Categories</h2>
                    <div class="d-flex flex-wrap gap-2">
                      {% if postCategories and postCategories.length > 0 %}
                        {% for cat in postCategories %}
                          {% if isLeanBuild %}
                          <span class="badge bg-light text-dark border fw-normal">{{ cat }}</span>
                          {% else %}
                          <a href="/religioustheory/categories/{{ cat | slugify }}/" class="badge bg-light text-dark border fw-normal text-decoration-none">{{ cat }}</a>
                          {% endif %}
                        {% endfor %}
                      {% else %}
                        <span class="small text-muted">None</span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="col-12 col-md-6">
                    <h2 class="h6 text-uppercase fw-bold small text-muted mb-2">Tags</h2>
                    <div class="d-flex flex-wrap gap-2">
                      {% if postTags and postTags.length > 0 %}
                        {% for tag in postTags %}
                          {% if isLeanBuild %}
                          <span class="badge bg-light text-dark border fw-normal">{{ tag }}</span>
                          {% else %}
                          <a href="/religioustheory/tags/{{ tag | slugify }}/" class="badge bg-light text-dark border fw-normal text-decoration-none">{{ tag }}</a>
                          {% endif %}
                        {% endfor %}
                      {% else %}
                        <span class="small text-muted">None</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </footer>
            {% endif %}
          </article>
        </div>
      {% else %}
        {{ content | safe }}
      {% endif %}
      {% if risCitationUrl or jsonCitationUrl %}
        <section class="my-4 pt-3 border-top">
          <div class="d-flex flex-wrap gap-2">
            {% if risCitationUrl %}
              <a href="{{ risCitationUrl }}" title="Download citation as RIS" class="btn btn-outline-primary" download>Download RIS</a>
            {% endif %}
            {% if jsonCitationUrl %}
              <a href="{{ jsonCitationUrl }}" title="Download citation as CSL JSON" class="btn btn-outline-secondary" download>Download Citation (CSL JSON)</a>
            {% endif %}
          </div>
        </section>
      {% endif %}
	    </main>
      <p class="h-card visually-hidden" data-pagefind-ignore>
        <a class="p-name u-url" href="https://thewhitestonefoundation.org/">The Whitestone Foundation</a>
      </p>
	  </div>
<script>
    (function () {
      const fallback = "/img/jcrt-open-graph.webp";
      const applyFallback = (img) => {
        if (!img || img.dataset.fallbackApplied === "1") return;
        img.dataset.fallbackApplied = "1";
        img.onerror = null;
        img.src = fallback;
      };
      function applyImageFallbacks() {
        const images = document.querySelectorAll("img");
        images.forEach((img) => {
          if (img.dataset.fallbackBound === "1") return;
          img.dataset.fallbackBound = "1";
          img.onerror = function () {
            if (this.dataset.fallbackAttempted === "1") {
              applyFallback(this);
              return;
            }
            this.dataset.fallbackAttempted = "1";
            this.src = this.dataset.fallbackSrc || fallback;
          };
        });
      }
      document.addEventListener(
        "error",
        (event) => {
          const img = event.target;
          if (!(img instanceof HTMLImageElement)) return;
          if (img.dataset.fallbackAttempted === "1") {
            applyFallback(img);
            return;
          }
          img.dataset.fallbackAttempted = "1";
          img.src = img.dataset.fallbackSrc || fallback;
        },
        true
      );
      const observer = new MutationObserver(() => applyImageFallbacks());
      observer.observe(document.documentElement, { childList: true, subtree: true });
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", applyImageFallbacks);
      } else {
        applyImageFallbacks();
      }
    })();
  </script>
  <script defer src="/js/bs.js"></script>
</body>
</html>
