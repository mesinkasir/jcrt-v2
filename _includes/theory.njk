<!DOCTYPE html>
<html lang="{{ metadata.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set pageTitle = title or pg.title or post.title or metadata.site.title %}
  {% set pageDesc = description or excerpt or abstract or pg.excerpt or post.excerpt or (content | striptags | trim | truncate(160)) or metadata.site.description %}
  {% set pageImageRaw = '/img/jcrt-open-graph.jpg' %}
  {% set pageImage = pageImageRaw if "http" in pageImageRaw else metadata.url + pageImageRaw %}
  {% set robotsDirective = "index, follow" %}
  {% if robots %}
    {% set robotsDirective = robots %}
  {% elif noindex or draft %}
    {% set robotsDirective = "noindex, follow" %}
  {% elif nofollow %}
    {% set robotsDirective = "index, nofollow" %}
  {% endif %}
  {% set canonicalPath = (canonical_url or page.url) | stripQueryAndHash %}
  {% set canonicalUrl = canonicalPath if "http" in canonicalPath else metadata.url + canonicalPath %}
  {% set defaultAuthor = "Religious Theory Editors" %}
  {% set pageAuthorCandidate = author or authors or pg.authorName or post.authorName or metadata.site.author or defaultAuthor %}
  {% set pageAuthor = pageAuthorCandidate %}
  {% if (not pageAuthor) or (pageAuthor | trim == "") or (pageAuthor | lower in ["editors", "editor", "editors_religioustheory"]) %}
    {% set pageAuthor = defaultAuthor %}
  {% endif %}
  {% set publishedDateRaw = date or post.date or page.date %}
  {% if (not publishedDateRaw) and year %}
    {% set publishedDateRaw = year ~ "-01-01" %}
  {% endif %}
  {% set publishedDate = publishedDateRaw | isoDate if publishedDateRaw else metadata.buildTime %}
  {% set modifiedDateRaw = lastmod or modified or updated or publishedDateRaw %}
  {% set modifiedDate = modifiedDateRaw | isoDate if modifiedDateRaw else publishedDate %}

  <title>{{ pageTitle }}</title>
  <meta name="title" content="{{ pageTitle }}" />
  <meta name="description" content="{{ pageDesc }}" />
  <meta name="language" content="{{ metadata.language }}" />
  <meta name="robots" content="{{ robotsDirective }}">
  <meta name="generator" content="{{ eleventy.generator }}" />
  <link rel="canonical" href="{{ canonicalUrl }}" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ canonicalUrl }}" />
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDesc }}" />
  <meta property="og:image" content="{{ pageImage }}" />
  <meta property="og:site_name" content="{{ metadata.site.title }}" />
  <meta property="og:locale" content="{{ metadata.locale }}" />
  <meta property="facebook:image" content="{{ pageImage }}" />
  <meta property="facebook:description" content="{{ pageDesc }}" />
  <meta property="facebook:author" content="{{ metadata.metasocial.facebook }}" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="{{ metadata.metasocial.twitter }}" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDesc }}" />
  <meta name="twitter:image" content="{{ pageImage }}" />
  <meta property="twitter:author" content="{{ metadata.metasocial.twitteruser }}" />

  <meta property="dc:title" content="{{ pageTitle }}" />
  <meta property="dc:creator" content="{{ pageAuthor }}" />
  <meta name="locale" content="{{ metadata.locale }}" />

  <link rel="icon" href="/img/logos/JCRT.svg" type="image/svg+xml" />
  <link rel="icon" href="/img/logos/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="icon" href="/img/logos/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/img/logos/favicon-48x48.png" type="image/png" sizes="48x48" />
  <link rel="icon" href="/img/logos/android-chrome-192x192.png" type="image/png" sizes="192x192" />
  <link rel="icon" href="/img/logos/android-chrome-512x512.png" type="image/png" sizes="512x512" />
  <link rel="apple-touch-icon" href="/img/logos/apple-touch-icon.png" sizes="180x180" />
  <script>
  (() => {
    const addManifest = () => {
      if (document.querySelector('link[rel="manifest"]')) return;
      const link = document.createElement("link");
      link.rel = "manifest";
      link.href = "/img/logos/site.webmanifest";
      document.head.appendChild(link);
    };
    const schedule = () => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(addManifest, { timeout: 3000 });
      } else {
        setTimeout(addManifest, 1500);
      }
    };
    if (document.readyState === "complete") schedule();
    else window.addEventListener("load", schedule, { once: true });
  })();
  </script>
  <meta name="theme-color" content="#ffffff" />

  <!-- use application/atom+xml for an atom feed -->
  <link rel="alternate" href="{{ metadata.url }}/feed/feed.xml" type="application/atom+xml" title="{{ metadata.site.title }}" />
  <link rel="alternate" href="{{ metadata.url }}/feed/feed.rss" type="application/rss+xml" title="{{ metadata.site.title }}" />
  <link rel="sitemap" href="{{ metadata.url }}/sitemap.xml" type="application/xml" title="{{ metadata.site.title }} Sitemap" />
  <meta name="site-generator" content="{{ eleventy.generator }}" />

  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
  <link rel="preload" href="/css/bs.css" as="style" />
  <link rel="preload" href="/css/index.css" as="style" />
  <link rel="preload" href="/css/font.css" as="style" />
  <link href="/css/bs.css" rel="stylesheet"/>
  <style>{% getBundle "css" %}</style>
  <link href="/css/font.css" rel="stylesheet"/>
  <link href="/css/index.css" rel="stylesheet"/>
  <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" rel="stylesheet"></noscript>
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "NGO",
    "@id": "https://thewhitestonefoundation.org",
    "name": "The Whitestone Foundation",
    "url": "https://thewhitestonefoundation.org",
    "logo": "{{ metadata.url }}{{ metadata.favicon }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Boulder",
      "addressRegion": "CO",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "{{ metadata.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ metadata.url }}/search/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
]
</script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ pageTitle }}",
    "description": "{{ pageDesc | truncate(160) }}",
    "image": "{{ pageImage }}",
    "datePublished": "{{ publishedDate }}",
    "dateModified": "{{ modifiedDate }}",
    "author": {
      "@type": "Person",
      "name": "{{ pageAuthor }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.site.title }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ metadata.url }}{{ metadata.favicon }}"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ metadata.url }}"
      },
      {% if pg or post %}
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Religious Theory",
        "item": "{{ metadata.url }}/religioustheory/"
      },
      {% endif %}
      {
        "@type": "ListItem",
        "position": {{ 3 if (pg or post) else 2 }},
        "name": "{{ pageTitle }}",
        "item": "{{ canonicalUrl }}"
      }
    ]
  }
  </script>
</head>
<body>
  {% include "partials/sidebar.njk" %}
<div id="content-wrapper" class="mse col-md-10 mx-auto ">
    <div class="col-md-12 p-3 mt-3 shadow rounded alert alert-danger alert-dismissible fade show" role="alert">
  {{metadata.site.alert |md | safe }}
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

    {% include "partials/nav_mobile.njk" %}
    <main class="h-entry" data-pagefind-body>
      {% set isTheoryPostDetail = page and page.inputPath and ("/content/religioustheory/posts/" in page.inputPath) %}
      {% if isTheoryPostDetail %}
        {% set defaultPostImage = "/img/jcrt-open-graph.webp" %}
        {% set postImage = (image | ensureImage(defaultPostImage)) %}
        {% set postAuthorRaw = author or authors %}
        {% set postAuthorNames = postAuthorRaw | splitAuthors if postAuthorRaw else [] %}
        {% set postDate = date or page.date %}
        {% set postCategories = categories or [] %}
        {% set postTags = tags | filterTagList if tags else [] %}

        <div class="container-fluid">
          <article class="py-4">
            <header class="mb-5 pb-2 border-bottom">
              <h1 class="serif fw-bold display-4 mb-4 p-name">{{ title }}</h1>

              <div class="mb-4">
                <img
                  src="{{ postImage }}"
                  data-fallback-src="{{ defaultPostImage }}"
                  alt="{{ title }}"
                  class="img-fluid rounded shadow-sm w-100"
                  {% imageAttrs postImage, 1200, 675 %}
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  style="max-height: 460px; object-fit: cover;"
                  onerror="this.onerror=null;this.src=this.dataset.fallbackSrc||'/img/jcrt-open-graph.webp';"
                >
              </div>

              {% if postAuthorNames and (postAuthorNames | length > 0) %}
                <div class="text-muted mb-2 p-author h-card">
                  <span class="fw-bold text-dark">By </span>
                  <span class="fw-bold text-dark p-name u-url">
                    {%- for aName in postAuthorNames -%}
                      {% set authorObj = collections.authors | getAuthorObj(aName) %}
                      {%- if (aName | lower) in ["editors", "editor"] -%}
                        <a href="/editors/" class="text-decoration-underline text-dark hover-primary">{{ aName }}</a>
                      {%- elif authorObj -%}
                        <a href="{{ authorObj.url }}" class="text-decoration-underline text-dark hover-primary">{{ aName }}</a>
                      {%- else -%}
                        {{ aName }}
                      {%- endif -%}
                      {%- if not loop.last -%}; {% endif -%}
                    {%- endfor -%}
                  </span>
                </div>
              {% endif %}

              {% if postDate %}
                <div class="small text-muted dt-published">
                  <i class="bi bi-calendar3"></i> {{ postDate | postDate }}
                </div>
              {% endif %}
            </header>

            <section class="article-body serif lh-lg e-content" style="font-size: 1.1rem;">
              {{ content | safe }}
            </section>

            {% if (postCategories and postCategories.length > 0) or (postTags and postTags.length > 0) %}
              <footer class="mt-5 pt-4 border-top">
                <div class="row g-4">
                  <div class="col-12 col-md-6">
                    <h2 class="h6 text-uppercase fw-bold small text-muted mb-2">Categories</h2>
                    <div class="d-flex flex-wrap gap-2">
                      {% if postCategories and postCategories.length > 0 %}
                        {% for cat in postCategories %}
                          <a href="/religioustheory/categories/{{ cat | slugify }}/" class="badge bg-light text-dark border fw-normal text-decoration-none">{{ cat }}</a>
                        {% endfor %}
                      {% else %}
                        <span class="small text-muted">None</span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="col-12 col-md-6">
                    <h2 class="h6 text-uppercase fw-bold small text-muted mb-2">Tags</h2>
                    <div class="d-flex flex-wrap gap-2">
                      {% if postTags and postTags.length > 0 %}
                        {% for tag in postTags %}
                          <a href="/religioustheory/tags/{{ tag | slugify }}/" class="badge bg-light text-dark border fw-normal text-decoration-none">{{ tag }}</a>
                        {% endfor %}
                      {% else %}
                        <span class="small text-muted">None</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </footer>
            {% endif %}
          </article>
        </div>
      {% else %}
        {{ content | safe }}
      {% endif %}
      {% if risCitationUrl or jsonCitationUrl %}
        <section class="my-4 pt-3 border-top">
          <div class="d-flex flex-wrap gap-2">
            {% if risCitationUrl %}
              <a href="{{ risCitationUrl }}" title="Download citation as RIS" class="btn btn-outline-primary" download>Download RIS</a>
            {% endif %}
            {% if jsonCitationUrl %}
              <a href="{{ jsonCitationUrl }}" title="Download citation as CSL JSON" class="btn btn-outline-secondary" download>Download Citation (CSL JSON)</a>
            {% endif %}
          </div>
        </section>
      {% endif %}
    </main>
  </div>
  <script>
    (function () {
      const fallback = "/img/jcrt-open-graph.webp";
      function applyImageFallbacks() {
        const images = document.querySelectorAll("img");
        images.forEach((img) => {
          if (!img.dataset.fallbackSrc) {
            img.dataset.fallbackSrc = fallback;
          }
          if (img.dataset.fallbackBound === "1") return;
          img.dataset.fallbackBound = "1";
          img.addEventListener("error", function () {
            const target = this.dataset.fallbackSrc || fallback;
            if (this.src.endsWith(target)) return;
            this.src = target;
          });
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", applyImageFallbacks);
      } else {
        applyImageFallbacks();
      }
    })();
  </script>
  <script defer src="/js/bs.js"></script>
</body>
</html>
