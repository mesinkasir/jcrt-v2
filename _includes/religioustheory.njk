}
/* Sidebar Wrapper - Responsive Default */
#teori-sidebar-wrapper {
    position: fixed !important;
    top: 0;
    left: -100%; /* Sembunyi total di mobile */
    width: 280px; /* Lebar standar mobile */
    height: 100vh;
    background: white;
    z-index: 1000000 !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    box-shadow: 5px 0 15px rgba(0,0,0,0.1);
}

/* Tablet & Desktop - Lebar lebih besar */
@media (min-width: 768px) {
    #teori-sidebar-wrapper {
        left: -350px;
        width: 320px;
    }
}

/* Overlay Mask */
.teori-overlay-mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(2px); /* Efek mewah di mobile */
    z-index: 999999;
    display: none;
    cursor: pointer;
}

/* LOGIKA CHECKBOX */
#teori-sidebar-trigger:checked ~ #teori-sidebar-wrapper {
    left: 0 !important;
}

#teori-sidebar-trigger:checked ~ .teori-overlay-mask {
