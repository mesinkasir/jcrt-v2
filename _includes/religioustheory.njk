<!doctype html>
<html lang="{{ metadata.language }}">
<meta name="viewport" content="width=device-width, initial-scale=1">
{% include "partials/seo.njk" %}
</head>
<body>
<input type="checkbox" id="teori-sidebar-trigger" class="teori-trigger-input" style="display:none;">

<label for="teori-sidebar-trigger" id="theory-toggle-btn" class="teori-btn-style">
    <i class="fa-solid fa-bars"></i>
</label>

<label for="teori-sidebar-trigger" class="teori-overlay-mask"></label>

<section id="teori-sidebar-wrapper">
    <div id="teori-inner-menu">

<div class="mb-3 p-3">
<link rel="preload" href="/pagefind/pagefind-ui.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link href="/pagefind/pagefind-ui.css" rel="stylesheet"></noscript>
<script defer src="/pagefind/pagefind-ui.js"></script>
<div id="search"></div>
<script>
    window.addEventListener('DOMContentLoaded', (event) => {
        const searchEl = document.querySelector("#search");
        const renderFallback = () => {
            if (!searchEl) return;
            searchEl.innerHTML = `
                <form action="/search/" method="get" role="search" style="display:flex;gap:8px;">
                    <input type="search" name="q" placeholder="Search" aria-label="Search" style="flex:1;min-width:0;padding:8px;border:1px solid #ccc;-webkit-appearance:none;box-sizing:border-box;">
                    <button type="submit" class="btn btn-primary btn-sm">Go</button>
                </form>
            `;
        };
        if (typeof PagefindUI !== "function") {
            renderFallback();
            return;
        }
        try {
            new PagefindUI({
                element: "#search",
                showSubResults: true,
                processResult: (result) => {
                    const currentTitle = result?.meta?.title || result?.title || "";
                    if (!currentTitle.trim()) {
                        const cleanPath = (result?.url || "").replace(/\/$/, "");
                        const fallbackTitle = decodeURIComponent(cleanPath.split("/").pop() || result?.url || "Untitled");
                        result.title = fallbackTitle.replace(/[-_]+/g, " ");
                    }
                    return result;
                }
            });
        } catch {
            renderFallback();
        }
    });
</script>
</div>

<main class="p-3 bg-light h-entry"> 
		
<h5 class="mb-4"><span class="bgb-primary p-1">{{metadata.sidebar.menu.title}}</span></h5>
<ul class="nav flex-column mb-5">
{% for n in metadata.sidebar.menu.list %}<li class="nav-item border-bottom mt-1 mb-1"><a href="{{n.url}}" class="nav-link text-uppercase smalls text-secondary">{{n.nav}}</a></li>{% endfor %}
</ul>

<div class="border-bottom">
<h5 class="mt-3 mb-5"><span class="bgb-primary p-1">{{metadata.sidebar.info.title}}</span></h5>
{% for i in metadata.sidebar.info.list %}<div class="mb-3">
{% set theorySideImg = i.image %}
<a href="{{i.url}}"><img class="img-fluid mb-3 rounded sidebar-square-img" alt="{{i.title}}" src="{{theorySideImg | preferWebp}}" data-fallback-src="{{theorySideImg}}" {% imageAttrs theorySideImg, 400, 400 %} loading="lazy" decoding="async" onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/img/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/img/jcrt-open-graph.webp';}"/></a>
<p class="smaller">{{i.text}}</p>
</div>{% endfor %}
<p><a href="{{metadata.sidebar.info.button.url}}" class="btn btn-s, btn-primary text-uppercase">{{metadata.sidebar.info.button.text}}</a></p>
</div>
			
<div class="smaller">
<h5 class="mt-3 mb-5"><span class="bgb-primary p-1">{{metadata.sidebar.contact.title}}</span></h5>
<p>
{{metadata.sidebar.contact.text}}
</p>
{% for c in metadata.sidebar.contact.list %}<p class="mb-3">
<i class="{{c.icon}} me-3 text-primary"></i>{% if c.url %}<a href="{{c.url}}">{{c.title}}</a>{% else %}{{c.title}}{% endif %}</p><hr/>{% endfor %}
</div>
			
<div class="mt-5">
