name: Deploy Eleventy to XMIT

on:
  push:
    branches: ["main", "master"]
  workflow_dispatch:
    inputs:
      site:
        description: "XMIT site/domain (e.g. jcrt.xmit.dev)"
        required: true
        type: string

concurrency:
  group: deploy-xmit-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

env:
  ELEVENTY_RUN_MODE: build
  NODE_OPTIONS: "--max-old-space-size=8192"
  SITE_URL: ${{ vars.SITE_URL || 'https://jcrt.org' }}
  XMIT_SITE: jcrt.xmit.dev@268

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          lfs: true

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Restore Eleventy Cache
        uses: actions/cache@v4
        with:
          path: .cache
          key: eleventy-cache-${{ runner.os }}-${{ hashFiles('content/**/*') }}
          restore-keys: |
            eleventy-cache-${{ runner.os }}-

      - name: Install dependencies
        run: npm ci --prefer-offline --no-audit

      - name: Build & Index
        run: |
          echo "🚀 Starting Build..."
          start_time=$(date +%s%3N)          
          # Eleventy BUild
          npm run build
          end_time=$(date +%s%3N)
          echo "⚡ Total process completed in $((end_time - start_time))ms"
          echo "📦 Stats: $(find _site -type f | wc -l) files, $(du -sh _site | cut -f1)"

      - name: Deploy to XMIT
        env:
          XMIT_KEY: ${{ secrets.XMIT_KEY }}
        run: |
          if [ -z "$XMIT_KEY" ]; then echo "❌ XMIT_KEY secret not set"; exit 1; fi          
          SITE="${{ github.event_name == 'workflow_dispatch' && inputs.site || env.XMIT_SITE }}"
          echo "🌐 Deploying to $SITE"          
          npx -y @xmit.co/xmit "$SITE" _site

      - name: Summary
        run: echo "✅ Successfully deployed to ${{ github.event_name == 'workflow_dispatch' && inputs.site || env.XMIT_SITE }}"

      - name: Notify Central Search Aggregator
        continue-on-error: true
        env:
          G_TOKEN: ${{ secrets.G_ACTION_TOKEN }}
        run: |
          if [ -z "$G_TOKEN" ]; then 
            echo "⚠️ G_ACTION_TOKEN not set, skipping notification."
          else
            curl -X POST https://api.github.com/repos/adamdjbrett/thewhitestonefoundation/dispatches \
            -H "Accept: application/vnd.github.v3+json" \
            -H "Authorization: bearer $G_TOKEN" \
            -d '{"event_type": "update_search_data"}'
          fi