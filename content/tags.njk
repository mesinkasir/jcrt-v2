---
layout: base.njk
---
<div class="container-fluid">

 {% include "partials/nav_desktop.njk" %}
<h1 class="display-5 fw-bold mb-5 border-bottom pb-3"><span class="border-bottom border-4 border-primary pb-2">
Tags
</span></h1>

<div class="row p-3">
{% for tag in collections | getKeys | filterTagList | sortAlphabetically %}
	{% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
	<div class="col-md-4 col-4 p-1">
		<a class="btn btn-outline-primary p-2" href="{{ tagUrl }}" class="post-tag">{{ tag }}</a></div>
{% endfor %}
</ul>

</div>