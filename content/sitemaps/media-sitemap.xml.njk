---
permalink: "/media-sitemap.xml"
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% set mediaFiles = collections.all | filter(entry => entry.outputPath.match(/\.(jpg|jpeg|png|gif|webp|svg|mp4|webm|avi|mov)$/i)) %}
{% for media in mediaFiles %}
  <url>
    <loc>{{ media.url | url }}</loc>
    <lastmod>{{ media.date | luxon("yyyy-MM-dd'T'HH:mm:ssZZ") }}</lastmod>
  </url>
{% endfor %}
</urlset>
