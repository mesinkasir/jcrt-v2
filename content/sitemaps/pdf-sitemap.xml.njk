---
permalink: "/pdf-sitemap.xml"
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% set pdfs = collections.all | filter(entry => entry.outputPath.endsWith('.pdf')) %}
{% for pdf in pdfs %}
  <url>
    <loc>{{ pdf.url | url }}</loc>
    <lastmod>{{ pdf.date | luxon("yyyy-MM-dd'T'HH:mm:ssZZ") }}</lastmod>
  </url>
{% endfor %}
</urlset>
