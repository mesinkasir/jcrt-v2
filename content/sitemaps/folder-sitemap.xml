---
permalink: "/folder-sitemap.xml"
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% set folders = collections.all | map(entry => entry.inputPath.split('/')[2]) | unique %}
{% set seen = [] %}
{% for folder in folders %}
  {% set url = '/' + folder + '/' %}
  {% if url not in seen %}
    <url>
      <loc>{{ url }}</loc>
      <lastmod>{{ collections.all | filter(entry => entry.inputPath.split('/')[2] == folder) | map(entry => entry.date) | max | luxonDate("yyyy-MM-dd'T'HH:mm:ssZZ") }}</lastmod>
    </url>
    {% set _ = seen.push(url) %}
  {% endif %}
{% endfor %}
</urlset>
