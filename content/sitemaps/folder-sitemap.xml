---
permalink: "/folder-sitemap.xml"
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% set folders = collections.all | map(entry => entry.inputPath.split('/')[2]) | unique %}
{% for folder in folders %}
  <url>
    <loc>{{ '/' + folder + '/' }}</loc>
    <lastmod>{{ collections.all | filter(entry => entry.inputPath.split('/')[2] == folder) | map(entry => entry.date) | max | luxon("yyyy-MM-dd'T'HH:mm:ssZZ") }}</lastmod>
  </url>
{% endfor %}
</urlset>
