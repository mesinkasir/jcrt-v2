---
layout: base.njk
pagination:
  data: collections.theoryPosts
  size: 25
  reverse: true
  alias: postlist
permalink: "/religioustheory/posts/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="collection-shell collection-shell--theory-posts">
  <div class="row">
    <div class="col-md-12">
      {% include "partials/nav_desktop.njk" %}
      <h1><strong><span class="border-bottom border-4 border-primary pb-2">Religious Theory Posts</span></strong></h1>

      <div class="col-md-12 border-top mt-5">
        <div class="row">
          {% for post in postlist %}
          <div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
            <div class="img-zoom-container rounded-4 shadow-sm mb-3 collection-card-media">
              <a href="{{ post.url }}" title="{{ post.data.title }}">
                {% set defaultCardImage = '/images/jcrt-open-graph.webp' %}
                {% set currentImg = (post.data.image | ensureImage(defaultCardImage)) %}
                {% set currentImgPreferred = (currentImg | preferWebp) %}
                <img class="img-post img-fluid collection-card-img"
                     alt="{{ post.data.title }}"
                     src="{{ currentImgPreferred }}"
                     data-fallback-src="{{ currentImg }}"
                     {% imageAttrs currentImg, 640, 360 %}
                     loading="lazy"
                     decoding="async"
                     onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}">
              </a>
            </div>

            <h3 class="serif fw-bold h5">
              <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
                {{ post.data.title }}
              </a>
            </h3>
            
            <div class="mb-2">
              {% set postAuthorRaw = post.data.author or "Editors" %}
              {% set postAuthorNames = postAuthorRaw | splitAuthors %}
              <p class="text-muted x-small text-uppercase fw-bold mb-1 collection-card-meta">
                {{ post.date | postDate if post.date else "Recently Published" }} 
                — By 
                <span class="text-primary">
                  {%- for aName in postAuthorNames -%}
                    {% set authorObj = collections.authors | getAuthorObj(aName) %}
                    {%- if (aName | lower) in ["editors", "editor"] -%}
                      <a href="/editors/" class="text-primary text-decoration-none hover-primary">{{ aName }}</a>
                    {%- elif authorObj and authorObj.url -%}
                      <a href="{{ authorObj.url }}" class="text-primary text-decoration-none hover-primary">{{ aName }}</a>
                    {%- else -%}
                      <a href="/authors/{{ aName | authorSlug }}/" class="text-primary text-decoration-none hover-primary">{{ aName }}</a>
                    {%- endif -%}
                    {%- if not loop.last -%}; {% endif -%}
                  {%- endfor -%}
                </span>
              </p>

              {% if post.data.categories %}
              <div class="d-flex flex-wrap gap-1 mb-2">
                {% for cat in post.data.categories %}
                {% if isLeanBuild %}
                <span class="text-primary fw-bold x-small border-end pe-1 me-1 collection-card-meta">
                  {{ cat }}
                </span>
                {% else %}
                <a href="/religioustheory/categories/{{ cat | slugify }}/" 
                   class="text-primary fw-bold text-decoration-none x-small border-end pe-1 me-1 collection-card-meta">
                  {{ cat }}
                </a>
                {% endif %}
                {% endfor %}
              </div>
              {% endif %}
            </div>

            <p class="text-secondary small">
              {% set postSummary = post.data.description or post.data.excerpt or post.data.abstract %}
              {{ postSummary | truncate(160) if postSummary else "Explore this latest article from our religious theory archive..." }}
            </p>

            <p class="mt-auto">
              <a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase collection-card-action">
                Learn More
              </a>
            </p>
          </div>
          {% endfor %}
        </div>

        {% set totalPages = pagination.pages.length %}
        {% set currentPage = pagination.pageNumber + 1 %}

        {% if totalPages > 1 %}
        <nav class="pagination-editorial border-top pt-5 mt-5 d-flex align-items-center justify-content-between px-md-5" role="navigation">
          <div class="d-flex align-items-center" style="flex: 1;">
            {% if pagination.href.previous %}
            <a href="{{ pagination.href.previous }}" class="btn-editorial-ghost me-3">← Newer</a>
            {% else %}
            <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
            {% endif %}
          </div>

          <div class="text-center d-none d-md-block" style="flex: 1;">
            {% if pagination.href.previous and pagination.href.next %}
            <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
            {% endif %}
          </div>

          <div class="text-end" style="flex: 1;">
            {% if pagination.href.next %}
            <a href="{{ pagination.href.next }}" class="btn-editorial-ghost">Older →</a>
            {% else %}
            {% if pagination.href.previous %}
            <span class="page-info text-secondary fw-bold small">Page {{ currentPage }} of {{ totalPages }}</span>
            {% endif %}
            {% endif %}
          </div>
        </nav>
        {% endif %}
      </div>
    </div>
  </div>
</div>
