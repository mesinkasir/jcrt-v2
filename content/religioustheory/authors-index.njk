---
layout: base.njk
title: Authors
permalink: /religioustheory/authors/index.html
---
<article class="collection-shell collection-shell--theory-authors mt-5">
  {% include "partials/nav_desktop.njk" %}

  <header class="mb-5">
    <h1>
      <strong>
        <span class="border-bottom border-4 border-primary pb-2">Authors</span>
      </strong>
    </h1>
  </header>

  <div class="row g-4 mb-5">
    {% for authorSlug in tagIndex.authors.theory.list %}
      {% set authorName = tagIndex.authors.theory.names[authorSlug] or authorSlug %}
      {% set postCount = tagIndex.authors.theory.counts[authorSlug] or 0 %}
      <div class="col-md-4 col-6">
        <a href="/religioustheory/authors/{{ authorSlug }}/" class="text-decoration-none">
          <div class="card h-100 shadow-sm border-0 bg-light transition-all hover-shadow">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
              <div>
                <h3 class="h5 fw-bold mb-0 text-dark">{{ authorName }}</h3>
                <span class="text-muted small">({{ postCount }} Articles)</span>
              </div>
              <span class="text-primary fw-bold">&rarr;</span>
            </div>
          </div>
        </a>
      </div>
    {% else %}
      <div class="col-12 text-center py-5">
        <p class="text-muted">No authors found.</p>
      </div>
    {% endfor %}
  </div>
</article>
