---js
{
  layout: "theory.njk",
  pagination: {
    data: "collections.theoryPosts",
    size: 1,
    alias: "tag",
    before: function(posts) {
      if (!posts || posts.length === 0) return [];
      
      const tagSet = new Set();
      for (const post of posts) {
        const tags = post.data?.tags || [];
        for (const t of tags) {
          if (typeof t === 'string' && t !== 'all') {
            tagSet.add(t);
          }
        }
      }
      return Array.from(tagSet).sort();
    }
  },
  permalink: "/religioustheory/tags/{{ tag | slugify }}/index.html",
  eleventyComputed: {
    title: "Tag: {{ tag }}"
  }
}
---
<article class="container-fluid mt-5">
  {% include "partials/nav_desktop.njk" %}
  
  <header class="mb-5 text-center">
    <h1 class="display-4 fw-bold serif">#{{ tag }}</h1>
    <p>
      <a class="text-primary fw-bold text-decoration-none text-uppercase" 
         style="font-size: 0.8rem; letter-spacing: 1px;" 
         href="/religioustheory/tags/">
        &larr; View All Tags
      </a>
    </p>
  </header>

  <div class="row mt-3 mb-3">
    {%- for post in collections.theoryPosts %}
      {%- set postTags = post.data.tags or [] -%}
      {%- if tag in postTags %}
        <div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
            <div class="img-zoom-container rounded-4 shadow-sm mb-3" style="aspect-ratio: 16/9; overflow: hidden;">
                <a href="{{ post.url }}">
                    <img class="img-post img-fluid" 
                         style="width: 100%; height: 100%; object-fit: cover;" 
                         alt="{{ post.data.title }}" 
                         src="{{ post.data.image or '/img/jcrt.jpg' }}"
                         onerror="this.onerror=null;this.src='/img/jcrt.jpg';">
                </a>
            </div>

            <h3 class="serif fw-bold h5">
                <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
                    {{ post.data.title }}
                </a>
            </h3>
            
            <p class="text-muted x-small text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">
                {{ post.date | postDate if post.date else "Recently Published" }}
                {% if post.data.author %} — By {{ post.data.author }}{% endif %}
            </p>

            <p class="text-secondary small">
                {{ post.data.excerpt | truncate(110) if post.data.excerpt else "Explore this article..." }}
            </p>

            <p>
                <a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">
                    Learn More
                </a>
            </p>
        </div>
      {%- endif %}
    {%- endfor %}
  </div>
</article>