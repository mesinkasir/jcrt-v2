---
layout: base.njk
title: Archive
permalink: /religioustheory/archive/index.html
---
<div class="collection-shell collection-shell--theory-archive">
  {% include "partials/nav_desktop.njk" %}

  <h1>Archive</h1>
  <p>Browse all {{ collections.theoryPosts | length }} posts.</p>

  {% set postsByYear = collections.theoryPosts | reverse | groupby("date.getFullYear()") %}
  {% for year, yearPosts in postsByYear | dictsort | reverse %}
    <h2 class="mt-4">{{ year }}</h2>
    <ul>
      {% for post in yearPosts %}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          {% if post.date %}
            <small> — {{ post.date | readableDate }}</small>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endfor %}
</div>
