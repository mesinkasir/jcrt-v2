---
layout: theory.njk
title: Blog
pagination:
  data: collections.theoryPosts
  size: 12
  alias: posts
  reverse: true
permalink: "/religioustheory/blog/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="container-fluid mt-5">
  {% include "partials/nav_desktop.njk" %}

  <header class="mb-5">
    <h1 class="serif fw-bold display-5">
      <strong><span class="border-bottom border-4 border-primary pb-2">Blog Archive</span></strong>
    </h1>
    <p class="text-muted mt-3">
      Showing page <strong>{{ pagination.pageNumber + 1 }}</strong> of <strong>{{ pagination.pages | length }}</strong> 
      (Total <strong>{{ collections.theoryPosts | length }}</strong> posts).
    </p>
  </header>

  <div class="row mt-3 mb-3">
    {%- for post in posts -%}
      <div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
        <div class="img-zoom-container rounded-4 shadow-sm mb-3" style="aspect-ratio: 16/9; overflow: hidden;">
          <a href="{{ post.url }}" title="{{ post.data.title }}">
            {% if post.data.image and post.data.image != 'null' and post.data.image != '' %}
              <img class="img-post img-fluid" style="width: 100%; height: 100%; object-fit: cover;" 
                   alt="{{ post.data.title }}" src="{{ post.data.image }}"
                   {% imageAttrs post.data.image, 640, 360 %}
                   loading="lazy"
                   decoding="async"
                   onerror="this.onerror=null;this.src='/img/jcrt.svg';">
            {% else %}
              <img class="img-post img-fluid" style="width: 100%; height: 100%; object-fit: cover;" 
                   alt="{{ post.data.title }}" src="/img/se.jpg"
                   {% imageAttrs '/img/se.jpg', 640, 360 %}
                   loading="lazy"
                   decoding="async"
                   onerror="this.onerror=null;this.src='/img/jcrt.svg';">
            {% endif %}
          </a>
        </div>

        <h3 class="serif fw-bold h5">
          <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
            {{ post.data.title }}
          </a>
        </h3>
        
        <p class="text-muted x-small text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">
          {% if post.date %}{{ post.date | postDate }}{% endif %}
          {% if post.data.author %} — By {{ post.data.author }}{% endif %}
        </p>

        <p class="text-secondary">
          {{ post.data.excerpt | truncate(110) if post.data.excerpt else "Explore this latest article from our archive..." }}
        </p>

        <p><a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">
          Learn More
        </a></p>
      </div>
    {%- endfor -%}
  </div>

  {% if pagination.pages | length > 1 %}
  <nav class="border-top pt-5 mt-5 d-flex align-items-center justify-content-between" role="navigation">
    <div>
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" class="btn btn-outline-primary fw-bold text-uppercase" style="font-size: 0.8rem;">← Newer Posts</a>
      {% endif %}
    </div>

    <div class="text-muted small fw-bold d-none d-md-block">
      PAGE {{ pagination.pageNumber + 1 }} OF {{ pagination.pages | length }}
    </div>

    <div>
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" class="btn btn-outline-primary fw-bold text-uppercase" style="font-size: 0.8rem;">Older Posts →</a>
      {% endif %}
    </div>
  </nav>
  {% endif %}
</div>
