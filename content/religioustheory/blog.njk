---
layout: base.njk
title: Blog
pagination:
  data: collections.theoryPosts
  size: 12
  alias: posts
  reverse: true
permalink: "/religioustheory/blog/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="collection-shell collection-shell--theory-blog mt-5">
  {% include "partials/nav_desktop.njk" %}

  <header class="mb-5">
    <h1 class="serif fw-bold display-5">
      <strong><span class="border-bottom border-4 border-primary pb-2">Blog Archive</span></strong>
    </h1>
    <p class="text-muted mt-3">
      Showing page <strong>{{ pagination.pageNumber + 1 }}</strong> of <strong>{{ pagination.pages | length }}</strong> 
      (Total <strong>{{ collections.theoryPosts | length }}</strong> posts).
    </p>
  </header>

  <div class="row mt-3 mb-3">
    {%- for post in posts -%}
      <div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
        <div class="img-zoom-container rounded-4 shadow-sm mb-3 collection-card-media">
          <a href="{{ post.url }}" title="{{ post.data.title }}">
            {% set defaultCardImage = '/images/jcrt-open-graph.webp' %}
            {% set blogCardImage = (post.data.image | ensureImage(defaultCardImage)) %}
            {% set blogCardImagePreferred = (blogCardImage | preferWebp) %}
            <img class="img-post img-fluid collection-card-img"
                 alt="{{ post.data.title }}" src="{{ blogCardImagePreferred }}" data-fallback-src="{{ blogCardImage }}"
                 {% imageAttrs blogCardImage, 640, 360 %}
                 loading="lazy"
                 decoding="async"
                 onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}">
          </a>
        </div>

        <h3 class="serif fw-bold h5">
          <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
            {{ post.data.title }}
          </a>
        </h3>
        
        <p class="text-muted x-small text-uppercase fw-bold mb-2 collection-card-meta">
          {% if post.date %}{{ post.date | postDate }}{% endif %}
          {% if post.data.author %} — By {{ post.data.author }}{% endif %}
        </p>

        <p class="text-secondary">
          {{ post.data.excerpt | truncate(110) if post.data.excerpt else "Explore this latest article from our archive..." }}
        </p>

        <p><a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase collection-card-action">
          Learn More
        </a></p>
      </div>
    {%- endfor -%}
  </div>

  {% if pagination.pages | length > 1 %}
  <nav class="border-top pt-5 mt-5 d-flex align-items-center justify-content-between" role="navigation">
    <div>
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" class="btn btn-outline-primary fw-bold text-uppercase collection-nav-action">← Newer Posts</a>
      {% endif %}
    </div>

    <div class="text-muted small fw-bold d-none d-md-block">
      PAGE {{ pagination.pageNumber + 1 }} OF {{ pagination.pages | length }}
    </div>

    <div>
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" class="btn btn-outline-primary fw-bold text-uppercase collection-nav-action">Older Posts →</a>
      {% endif %}
    </div>
  </nav>
  {% endif %}
</div>
