---
layout: base.njk
pagination:
  data: collections.theoryAuthors
  size: 1
  alias: authorName
permalink: "/religioustheory/authors/{{ authorName | slugify }}/index.html"
eleventyComputed:
  title: "Author: {{ authorName }}"
---
<article class="container-fluid mt-5">
  {% include "partials/nav_desktop.njk" %}
  
  <header class="mb-5 text-center">
    <h1 class="display-4 fw-bold serif">{{ authorName }}</h1>
    <p>
      <a class="text-primary fw-bold text-decoration-none text-uppercase" 
         style="font-size: 0.8rem; letter-spacing: 1px;" 
         href="/religioustheory/authors/">
        &larr; View All Authors
      </a>
    </p>
  </header>

  <div class="row mt-3 mb-3">
    {%- for post in collections.theoryPosts %}
      {% set postAuthor = post.data.author or "Editors" %}
      
      {%- if postAuthor == authorName %}
        <div class="col-md-6 col-lg-4 p-3 small p-md-5 d-flex flex-column"> 
            <div class="img-zoom-container rounded-4 shadow-sm mb-3" style="aspect-ratio: 16/9; overflow: hidden;">
                <a href="{{ post.url }}">
                    {% set authorCardImage = (post.data.image | ensureImage('/images/jcrt-open-graph.webp')) %}
                    {% set authorCardImagePreferred = (authorCardImage | preferWebp) %}
                    <img class="img-post img-fluid" 
                         style="width: 100%; height: 100%; object-fit: cover;" 
                         alt="{{ post.data.title }}" 
                         src="{{ authorCardImagePreferred }}"
                         data-fallback-src="{{ authorCardImage }}"
                         {% imageAttrs authorCardImage, 640, 360 %}
                         loading="lazy"
                         decoding="async"
                         onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}">
                </a>
            </div>

            <h3 class="serif fw-bold h5">
                <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
                    {{ post.data.title }}
                </a>
            </h3>
            
            <div class="mb-2">
                <p class="text-muted x-small text-uppercase fw-bold mb-1" style="font-size: 0.7rem;">
                    {% if post.date %}{{ post.date | postDate }}{% endif %}
                    — By {{ postAuthor }}
                </p>
            </div>

            <p class="text-secondary small">
                {{ post.data.excerpt | truncate(110) if post.data.excerpt else "Explore this article by " + authorName + "..." }}
            </p>

            <p class="mt-auto">
                <a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">
                    Learn More
                </a>
            </p>
        </div>
      {%- endif %}
    {%- endfor %}
  </div>
</article>
