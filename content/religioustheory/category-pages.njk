---js
{
  pagination: {
    data: "collections.theoryPosts",
    size: 1,
    alias: "category",
    before: function(posts) {
      if (!posts || posts.length === 0) return [];
      const catSet = new Set();
      for (const post of posts) {
        // Akses data melalui post.data
        const cats = post.data?.categories || [];
        for (const c of cats) {
          if (typeof c === 'string') {
            catSet.add(c);
          }
        }
      }
      return Array.from(catSet).sort();
    }
  },
  layout: "theory.njk",
  eleventyComputed: {
    title: "Category: {{ category }}",
    permalink: "/religioustheory/categories/{{ category | slugify }}/index.html"
  }
}
---
<div class="container-fluid mt-5">
  {% include "partials/nav_desktop.njk" %}

  <header class="mb-5">
    <h1 class="display-5 fw-bold">
      <strong><span class="border-bottom border-4 border-primary pb-2">Category: {{ category }}</span></strong>
      <a href="/religioustheory/categories/" class="btn btn-primary float-end">← Back to categories</a>
    </h1>
  </header>

  <div class="row mt-3 mb-3">
    {%- for post in collections.theoryPosts %}
      {%- set postCats = post.data.categories or [] -%}
      {%- if category in postCats %}
        <div class="col-md-6 col-lg-4 p-3 small p-md-5 d-flex flex-column"> 
            
            <div class="img-zoom-container rounded-4 shadow-sm mb-3" style="aspect-ratio: 16/9; overflow: hidden;">
                <a href="{{ post.url }}">
                    {% set categoryCardImage = post.data.image or '/img/jcrt.svg' %}
                    <img class="img-post img-fluid" 
                         style="width: 100%; height: 100%; object-fit: cover;" 
                         alt="{{ post.data.title }}" 
                         src="{{ categoryCardImage | preferWebp }}"
                         data-fallback-src="{{ categoryCardImage }}"
                         {% imageAttrs categoryCardImage, 640, 360 %}
                         loading="lazy"
                         decoding="async"
                         onerror="if(this.dataset.fallbackSrc&&this.src!==this.dataset.fallbackSrc){this.src=this.dataset.fallbackSrc;}else{this.onerror=null;this.src='/img/jcrt.svg';}">
                </a>
            </div>

            <h3 class="serif fw-bold h5">
                <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
                    {{ post.data.title }}
                </a>
            </h3>
            
            <div class="mb-2">
                <p class="text-muted x-small text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                    {{ post.date | postDate if post.date else "Recently Published" }}
                    {% if post.data.author %}
                      — By <span class="text-primary">{{ post.data.author }}</span>
                    {% endif %}
                </p>

                <div class="d-flex flex-wrap gap-1 mb-2">
                    {% for cat in postCats %}
                        <a href="/religioustheory/categories/{{ cat | slugify }}/" 
                           class="text-primary fw-bold text-decoration-none x-small border-end pe-1 me-1" 
                           style="font-size: 0.7rem; border-color: var(--primary-jcrt) !important;">
                            {{ cat }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <p class="text-secondary small">
                {{ post.data.excerpt | truncate(110) if post.data.excerpt else "Explore this article..." }}
            </p>

            <p class="mt-auto">
                <a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">
                    Learn More
                </a>
            </p>
        </div>
      {%- endif %}
    {%- endfor %}
  </div>
</div>
