---js
{
  pagination: {
    data: "tagIndex.theory.categories.paginationList",
    size: 1,
    alias: "category"
  },
  layout: "base.njk",
  eleventyComputed: {
    title: "Category: {{ category }}",
    permalink: "/religioustheory/categories/{{ category | slugify }}/index.html"
  }
}
---
<div class="collection-shell collection-shell--theory-category mt-5">
  {% include "partials/nav_desktop.njk" %}

  <header class="mb-5">
    <h1 class="display-5 fw-bold">
      <strong><span class="border-bottom border-4 border-primary pb-2">Category: {{ category }}</span></strong>
      <a href="/religioustheory/categories/" class="btn btn-primary float-end">← Back to categories</a>
    </h1>
  </header>

  <div class="row mt-3 mb-3">
    {%- set categoryPosts = tagIndex.theory.categories.map[category] or [] -%}
    {%- for post in categoryPosts %}
        <div class="col-md-6 col-lg-4 p-3 small p-md-5 d-flex flex-column"> 
            
            <div class="img-zoom-container rounded-4 shadow-sm mb-3 collection-card-media">
                <a href="{{ post.url }}">
                    {% set defaultCardImage = '/images/jcrt-open-graph.webp' %}
                    {% set categoryCardImage = (post.image | ensureImage(defaultCardImage)) %}
                    {% set categoryCardImagePreferred = (categoryCardImage | preferWebp) %}
                    <img class="img-post img-fluid collection-card-img"
                         alt="{{ post.title }}"
                         src="{{ categoryCardImagePreferred }}"
                         data-fallback-src="{{ categoryCardImage }}"
                         {% imageAttrs categoryCardImage, 640, 360 %}
                         loading="lazy"
                         decoding="async"
                         onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}">
                </a>
            </div>

            <h3 class="serif fw-bold h5">
                <a class="text-decoration-none text-dark hover-primary" href="{{ post.url }}">
                    {{ post.title }}
                </a>
            </h3>
            
            <div class="mb-2">
                <p class="text-muted x-small text-uppercase fw-bold mb-1 collection-card-meta">
                    {{ post.date | postDate if post.date else "Recently Published" }}
                    {% if post.author %}
                      — By <span class="text-primary">{{ post.author }}</span>
                    {% endif %}
                </p>
            </div>

            <p class="text-secondary small">
                {{ post.description | truncate(160) if post.description else "Explore this article..." }}
            </p>

            <p class="mt-auto">
                <a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase collection-card-action">
                    Learn More
                </a>
            </p>
        </div>
    {%- endfor %}
  </div>
</div>
