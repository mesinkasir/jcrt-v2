---
layout: theory.njk
permalink: /religioustheory/pages/index.html
---
<div class="container-fluid">
  {% include "partials/nav_desktop.njk" %}
<h1>Static Pages</h1>
{% set defaultPageImage = '/img/jcrt-open-graph.webp' %}
{% set firstTheoryPage = (collections.theoryPages | first) %}
{% set firstTheoryPageImage = defaultPageImage %}
{% if firstTheoryPage and firstTheoryPage.data and firstTheoryPage.data.image %}
  {% set firstTheoryPageImage = (firstTheoryPage.data.image | ensureImage(defaultPageImage)) %}
{% endif %}
{% set firstTheoryPageImagePreferred = (firstTheoryPageImage | preferWebp) %}
<div class="mb-4">
  <img
    src="{{ firstTheoryPageImagePreferred }}"
    data-fallback-src="{{ firstTheoryPageImage }}"
    alt="Religious Theory"
    {% imageAttrs firstTheoryPageImage, 1200, 675 %}
    class="img-fluid rounded shadow-sm w-100"
    loading="lazy"
    decoding="async"
    style="max-height: 320px; object-fit: cover;"
    onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/img/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/img/jcrt-open-graph.webp';}">
</div>

<ul>
{% for pg in collections.theoryPages %}
  <li class="p-3">
    <strong>
      <a href="/religioustheory/{{ pg.slug | slugify }}/">{{ pg.title }}</a>
    </strong>
    <p><small>Source Path: {{ pg.path }}</small></p>
  </li>
{% else %}
  <li>No static pages found in archive.</li>
{% endfor %}
</ul>

</div>
