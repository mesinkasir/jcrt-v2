---
layout: theory.njk
title: Religious Theory
description: Digital archive for JCRT Theory, Culture, and Religion.
permalink: /religioustheory/index.html
---

<div class="container-fluid">

 {% include "partials/nav_desktop.njk" %}

  <header class="mt-3 mb-3">
    <h1><strong><span class="border-bottom border-4 border-primary pb-2">Religious Theory Archive</span></strong></h1>
  </header>

<section class="mt-5">  
  <div class="row mt-3 mb-3">
<section class="mt-5">  
  <div class="row mt-3 mb-3">
    {% set posts = collections.theoryPosts | reverse %}
    {% for post in posts.slice(0, 6) %}
    <div class="col-md-6 col-lg-4 p-3 small p-md-5"> 
        <div class="img-zoom-container rounded-4 shadow-sm mb-3" style="aspect-ratio: 16/9; overflow: hidden;">
            <a href="{{ post.url }}" title="{{ post.data.title }}">
                {% set defaultCardImage = '/images/jcrt-open-graph.webp' %}
                {% set cardImage = (post.data.image | ensureImage(defaultCardImage)) %}
                {% set cardImagePreferred = (cardImage | preferWebp) %}
                <img class="img-post img-fluid" 
                     style="width: 100%; height: 100%; object-fit: cover;" 
                     alt="{{ post.data.title }}" 
                     src="{{ cardImagePreferred }}"
                     data-fallback-src="{{ cardImage }}"
                     {% imageAttrs cardImage, 640, 360 %}
                     loading="lazy"
                     decoding="async"
                     onerror="if(this.dataset.fallbackAttempted){this.onerror=null;this.src='/images/jcrt-open-graph.webp';}else{this.dataset.fallbackAttempted='1';this.src=this.dataset.fallbackSrc||'/images/jcrt-open-graph.webp';}">
            </a>
        </div>

        <h3 class="serif fw-bold h5">{{ post.data.title }}</h3>   
        
        <p class="text-muted x-small text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">
            {{ post.data.date | postDate if post.data.date else "Recently Published" }} 
            {% if post.data.author %} — By {{ post.data.authorData.name or post.data.author }}{% endif %}
        </p>

        <p class="text-secondary">
            {{ post.data.description | truncate(160) if post.data.description else (post.data.excerpt | truncate(120) if post.data.excerpt else "Explore this latest article...") }}
        </p>

        <p><a href="{{ post.url }}" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">
            Learn More
        </a></p>
    </div>
    {% else %}
    <div class="col-12 text-center">
        <p>No posts found in theoryPosts collection.</p>
    </div>
    {% endfor %}
  </div>
</section>
</div>

  <div class="col-12 p-3 p-md-5 text-center mt-4 mb-3">
    <a href="/religioustheory/posts/" 
    class="btn btn-primary px-4 py-2 text-uppercase fw-bold" style="letter-spacing: 1px;">
      View All Articles
    </a>
  </div>
</section>


</div>
