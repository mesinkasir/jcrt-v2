---
layout: theory.njk
title: Tags & Categories Archive
permalink: /religioustheory/taxonomy/index.html
---

<div class="container-fluid">
  {% include "partials/nav_desktop.njk" %}
  <h1 class="display-5 fw-bold mb-5 border-bottom pb-3">Digital Archive Index</h1>
  
  <div class="row">
    <div class="col-md-12 mb-5">
      <h3 class="h4 text-uppercase mb-4 fw-bold text-primary">Categories</h3>
      
      
      {% set allCats = [] %}
      {% for post in collections.theoryPosts %}
        {% for cat in post.data.categories %}
          {% if cat not in allCats %}
            {% set allCats = (allCats.push(cat), allCats) %}
          {% endif %}
        {% endfor %}
      {% endfor %}

      {% for cat in allCats | sort %}
        {% set catCount = 0 %}
        <details class="mb-3 border-bottom pb-2">
          <summary class="d-flex justify-content-between align-items-center fw-bold cursor-pointer">
            {{ cat | capitalize }}
            
            {% for post in collections.theoryPosts %}
              {% if post.data.categories and cat in post.data.categories %}
                {% set catCount = catCount + 1 %}
              {% endif %}
            {% endfor %}
            <span class="badge bg-light text-muted border rounded-pill small">{{ catCount }} Posts</span>
          </summary>
          <div class="mt-3 ps-3 border-start">
            {% for post in collections.theoryPosts %}
              {% if post.data.categories and cat in post.data.categories %}
                <div class="mb-2">
                  <a href="{{ post.url }}" class="text-decoration-none text-secondary small hover-primary">
                    • {{ post.data.title }}
                  </a>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </details>
      {% endfor %}
    </div>

    <div class="col-md-12 mb-5">
      <h3 class="h4 text-uppercase mb-4 fw-bold text-primary">Tags</h3>
      
      {% set allTags = [] %}
      {% for post in collections.theoryPosts %}
        {% for tag in post.data.tags %}
          {% if tag != "theoryPosts" and tag != "all" and tag not in allTags %}
            {% set allTags = (allTags.push(tag), allTags) %}
          {% endif %}
        {% endfor %}
      {% endfor %}

      {% for tag in allTags | sort %}
        {% set tagCount = 0 %}
        <details class="mb-3 border-bottom pb-2">
          <summary class="d-flex justify-content-between align-items-center fw-bold cursor-pointer">
            #{{ tag | upper }}
            {% for post in collections.theoryPosts %}
              {% if post.data.tags and tag in post.data.tags %}
                {% set tagCount = tagCount + 1 %}
              {% endif %}
            {% endfor %}
            <span class="badge bg-light text-muted border rounded-pill small">{{ tagCount }} Posts</span>
          </summary>
          <div class="mt-3 ps-3 border-start">
            {% for post in collections.theoryPosts %}
              {% if post.data.tags and tag in post.data.tags %}
                <div class="mb-2">
                  <a href="{{ post.url }}" class="text-decoration-none text-secondary small hover-primary">
                    • {{ post.data.title }}
                  </a>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</div>