/.well-known/traffic-advice
  Content-Type: application/trafficadvice+json

/css/*
  Cache-Control: public, max-age=345600, stale-while-revalidate=604800

/js/*
  Cache-Control: public, max-age=345600, stale-while-revalidate=604800

/images/*
  Cache-Control: public, max-age=172800, stale-while-revalidate=2592000
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Accept, Range
  Access-Control-Expose-Headers: Content-Length, Content-Range, ETag

/images/logos/site.webmanifest
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Accept, Range

/pagefind/*
  Cache-Control: public, max-age=172800, stale-while-revalidate=604800
